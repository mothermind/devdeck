---
---

<header class="site-header">
  <!-- Left: identity -->
  <div class="header-identity">
    <img src="/profile.jpeg" alt="Ayden Choi" class="avatar" />
    <div class="identity-text">
      <span class="profile-name">Ayden Choi</span>
      <span class="profile-role">Data Engineer</span>
    </div>
  </div>

  <!-- Center: search -->
  <div class="search-wrap">
    <div class="search-bar" id="search-trigger" role="button" tabindex="0" aria-label="Search pages">
      <svg class="search-icon" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/>
      </svg>
      <span class="search-placeholder">Search pages...</span>
      <kbd class="search-kbd">⌘K</kbd>
    </div>

    <!-- Dropdown -->
    <div class="search-dropdown" id="search-dropdown" hidden>
      <input
        id="search-input"
        class="search-input"
        type="text"
        placeholder="Search pages..."
        autocomplete="off"
        spellcheck="false"
      />
      <ul class="search-results" id="search-results"></ul>
    </div>
  </div>

  <!-- Right: links -->
  <div class="header-links">
    <a href="https://github.com/cch0213" target="_blank" rel="noopener" class="header-link">
      <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor">
        <path d="M12 2C6.477 2 2 6.477 2 12c0 4.418 2.865 8.166 6.839 9.489.5.092.682-.217.682-.482 0-.237-.009-.868-.013-1.703-2.782.604-3.369-1.342-3.369-1.342-.454-1.155-1.11-1.462-1.11-1.462-.908-.62.069-.608.069-.608 1.003.07 1.531 1.03 1.531 1.03.892 1.529 2.341 1.087 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.11-4.555-4.943 0-1.091.39-1.984 1.029-2.683-.103-.253-.446-1.27.098-2.647 0 0 .84-.269 2.75 1.025A9.578 9.578 0 0 1 12 6.836a9.59 9.59 0 0 1 2.504.337c1.909-1.294 2.747-1.025 2.747-1.025.546 1.377.203 2.394.1 2.647.64.699 1.028 1.592 1.028 2.683 0 3.842-2.339 4.687-4.566 4.935.359.309.678.919.678 1.852 0 1.336-.012 2.415-.012 2.743 0 .267.18.579.688.481C19.138 20.163 22 16.418 22 12c0-5.523-4.477-10-10-10z"/>
      </svg>
      GitHub
    </a>
    <span class="link-sep">·</span>
    <a href="https://www.linkedin.com/in/aydenccc/" target="_blank" rel="noopener" class="header-link">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor">
        <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
      </svg>
      LinkedIn
    </a>
    <span class="link-sep">·</span>
    <a href="mailto:aydenchoi213@gmail.com" class="header-link">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/>
      </svg>
      Email
    </a>
  </div>
</header>

<script>
  const PAGES = [
    { label: 'Dashboard',              section: 'Home',             href: '/' },
    { label: 'Pipeline',               section: 'Data Pipeline',    href: '/project1/pipeline' },
    { label: 'Scrapers',               section: 'Data Pipeline',    href: '/project1/scrapers' },
    { label: 'Sentiment Analysis',     section: 'Data Pipeline',    href: '/project1/sentiment' },
    { label: 'Ingredient Embeddings',  section: 'Data Pipeline',    href: '/project1/ingredient-embeddings' },
    { label: 'Search Trend',           section: 'Data Pipeline',    href: '/project1/search-trend' },
    { label: 'Table Manager',          section: 'Data Pipeline',    href: '/project1/table-manager' },
    { label: 'Hypothesis Explorer',    section: 'Lab',              href: '/project2/hypothesis-explorer' },
    { label: 'Git, But Make It Excel',   section: 'Cheatsheet',       href: '/cheatsheet/git-excel' },
    { label: 'Table Version Manager',    section: 'Agent Docs',       href: '/agent-docs/table-manager' },
  ];

  const trigger  = document.getElementById('search-trigger')!;
  const dropdown = document.getElementById('search-dropdown')!;
  const input    = document.getElementById('search-input') as HTMLInputElement;
  const results  = document.getElementById('search-results')!;

  function open() {
    dropdown.hidden = false;
    input.focus();
    render('');
  }

  function close() {
    dropdown.hidden = true;
    input.value = '';
  }

  function render(q: string) {
    const query = q.toLowerCase().trim();
    const matches = query
      ? PAGES.filter(p =>
          p.label.toLowerCase().includes(query) ||
          p.section.toLowerCase().includes(query)
        )
      : PAGES;

    results.innerHTML = '';
    matches.forEach(p => {
      const li = document.createElement('li');
      li.innerHTML = `
        <a href="${p.href}" class="result-item">
          <span class="result-label">${p.label}</span>
          <span class="result-section">${p.section}</span>
        </a>`;
      results.appendChild(li);
    });
  }

  trigger.addEventListener('click', open);
  trigger.addEventListener('keydown', (e) => { if (e.key === 'Enter' || e.key === ' ') open(); });
  input.addEventListener('input', () => render(input.value));
  input.addEventListener('keydown', (e) => { if (e.key === 'Escape') close(); });

  // ⌘K / Ctrl+K
  document.addEventListener('keydown', (e) => {
    if ((e.metaKey || e.ctrlKey) && e.key === 'k') {
      e.preventDefault();
      dropdown.hidden ? open() : close();
    }
  });

  // Close on outside click
  document.addEventListener('click', (e) => {
    if (!dropdown.hidden && !trigger.contains(e.target as Node) && !dropdown.contains(e.target as Node)) {
      close();
    }
  });

  // Close on result click
  results.addEventListener('click', close);
</script>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 200;
    width: 100%;
    height: var(--header-h);
    display: grid;
    grid-template-columns: auto auto 1fr;
    align-items: center;
    padding: 0 1.5rem;
    background: rgba(250, 246, 240, 0.92);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--border);
    gap: 1.5rem;
  }

  /* ── Left: identity ── */
  .header-identity {
    display: flex;
    align-items: center;
    gap: 0.55rem;
    min-width: 0;
  }

  .avatar {
    width: 26px;
    height: 26px;
    border-radius: 50%;
    object-fit: cover;
    flex-shrink: 0;
  }

  .identity-text {
    display: flex;
    flex-direction: column;
    line-height: 1.25;
    min-width: 0;
  }

  .profile-name {
    font-size: 0.85rem;
    font-weight: 500;
    color: var(--text);
    white-space: nowrap;
  }

  .profile-role {
    font-size: 0.72rem;
    color: var(--text-dim);
    white-space: nowrap;
  }

  /* ── Center: search ── */
  .search-wrap {
    position: relative;
    width: 260px;
    flex-shrink: 0;
    margin-left: 8.2rem;
  }

  .search-bar {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    height: 36px;
    padding: 0 0.75rem;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 10px;
    cursor: pointer;
    transition: border-color 0.15s;
    user-select: none;
  }

  .search-bar:hover { border-color: var(--border-hi); }
  .search-bar:focus { outline: none; border-color: var(--accent); }

  .search-icon { color: var(--text-dim); flex-shrink: 0; }

  .search-placeholder {
    flex: 1;
    font-family: var(--font-sans);
    font-size: 0.78rem;
    color: var(--text-dim);
  }

  .search-kbd {
    font-family: var(--font-sans);
    font-size: 0.65rem;
    color: var(--text-dim);
    background: var(--bg);
    border: 1px solid var(--border);
    border-radius: 4px;
    padding: 0.1em 0.4em;
    flex-shrink: 0;
  }

  /* ── Dropdown ── */
  .search-dropdown {
    position: absolute;
    top: calc(100% + 6px);
    left: 0;
    right: 0;
    background: var(--surface);
    border: 1px solid var(--border-hi);
    border-radius: 12px;
    overflow: hidden;
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.1);
    z-index: 300;
  }

  .search-input {
    width: 100%;
    height: 40px;
    padding: 0 0.9rem;
    background: transparent;
    border: none;
    border-bottom: 1px solid var(--border);
    font-family: var(--font-sans);
    font-size: 0.85rem;
    color: var(--text);
    outline: none;
  }

  .search-input::placeholder { color: var(--text-dim); }

  .search-results {
    list-style: none;
    padding: 0.3rem;
    margin: 0;
    max-height: 280px;
    overflow-y: auto;
  }

  .result-item {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0.5rem 0.75rem;
    border-radius: 8px;
    text-decoration: none;
    transition: background 0.1s;
    gap: 0.75rem;
  }

  .result-item:hover {
    background: rgba(0, 0, 0, 0.04);
    text-decoration: none;
  }

  .result-label {
    font-family: var(--font-sans);
    font-size: 0.85rem;
    color: var(--text);
  }

  .result-section {
    font-family: var(--font-sans);
    font-size: 0.72rem;
    color: var(--text-dim);
    white-space: nowrap;
  }

  /* ── Right: links ── */
  .header-links {
    display: flex;
    align-items: center;
    justify-content: flex-end;
    margin-left: auto;
    gap: 0.75rem;
  }

  .header-link {
    display: flex;
    align-items: center;
    gap: 0.35rem;
    font-size: 0.8rem;
    color: var(--text-muted);
    text-decoration: none;
    transition: color 0.15s;
    white-space: nowrap;
  }

  .header-link:hover { color: var(--text); text-decoration: none; }
  .header-link svg { flex-shrink: 0; }

  .link-sep {
    font-size: 0.72rem;
    color: var(--border-hi);
  }

  /* ── Responsive ── */
  @media (max-width: 900px) {
    .site-header {
      grid-template-columns: auto 1fr auto;
    }
    .search-wrap { width: auto; }
    .profile-role { display: none; }
    .result-section { display: none; }
  }
</style>
