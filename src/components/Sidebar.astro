---
const pathname = Astro.url.pathname;

const nav = [
  {
    section: 'Home',
    links: [
      { href: '/', label: 'Dashboard' },
    ],
  },
  {
    section: 'Data Pipeline',
    links: [
      { href: '/project1/pipeline',                label: 'Pipeline' },
      { href: '/project1/scrapers',                label: 'Scrapers' },
      { href: '/project1/sentiment',               label: 'Sentiment Analysis' },
      { href: '/project1/ingredient-embeddings',   label: 'Ingredient Embeddings' },
      { href: '/project1/search-trend',            label: 'Search Trend' },
      { href: '/project1/table-manager',           label: 'Table Manager' },
    ],
  },
  {
    section: 'Lab',
    links: [
      { href: '/project2/hypothesis-explorer', label: 'Hypothesis Explorer' },
    ],
  },
  {
    section: 'Cheatsheet',
    links: [
      { href: '/cheatsheet/git-excel', label: 'Git, But Make It Excel', external: true },
    ],
  },
];

function isActive(href: string) {
  if (href === '/') return pathname === '/';
  return pathname.startsWith(href);
}
---

<aside class="sidebar" id="sidebar">
  <!-- Close button: visible only in drawer mode -->
  <button class="sidebar-close" id="sidebar-close" aria-label="Close navigation">
    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <line x1="18" y1="6" x2="6" y2="18"/>
      <line x1="6" y1="6" x2="18" y2="18"/>
    </svg>
  </button>

  <div class="sidebar-inner">
    <nav>
      {nav.map(({ section, links }) => (
        <div class="nav-section">
          <div class="section-label">{section}</div>
          {links.map((link) => (
            <a
              href={link.href}
              class:list={['nav-link', { active: isActive(link.href) }]}
              {...(link.external ? { target: '_blank', rel: 'noopener' } : {})}
            >
              {link.label}
              {link.external && <span class="external-icon">↗</span>}
            </a>
          ))}
        </div>
      ))}
    </nav>

    <div class="agent-api-section">
      <div class="section-label">Agent API</div>
      <a href="/api/docs/index.json" class="nav-link api-link" target="_blank" rel="noopener">{ } docs index ↗</a>
      <a href="/api/dashboard.json" class="nav-link api-link" target="_blank" rel="noopener">{ } dashboard ↗</a>
      <a href="/llms.txt" class="nav-link api-link" target="_blank" rel="noopener">{ } llms.txt ↗</a>
    </div>

  </div>
</aside>

<style>
  .sidebar {
    position: fixed;
    top: var(--header-h);
    left: 0;
    width: var(--sidebar-w);
    height: calc(100vh - var(--header-h));
    background: var(--sidebar-bg);
    border-right: 1px solid var(--border);
    display: flex;
    flex-direction: column;
    z-index: 100;
    overflow: hidden;
  }

  .sidebar-inner {
    flex: 1;
    overflow-y: auto;
    padding: 1.5rem 0.85rem 2.5rem;
    scrollbar-width: thin;
    scrollbar-color: var(--border) transparent;
  }

  .sidebar-inner::-webkit-scrollbar { width: 4px; }
  .sidebar-inner::-webkit-scrollbar-thumb { background: var(--border); border-radius: 2px; }

  /* ── Close button (drawer mode only) ── */
  .sidebar-close {
    display: none; /* hidden on desktop */
    position: absolute;
    top: 0.75rem;
    right: 0.75rem;
    width: 30px;
    height: 30px;
    align-items: center;
    justify-content: center;
    background: none;
    border: 1px solid var(--border);
    border-radius: 8px;
    color: var(--text-muted);
    cursor: pointer;
    padding: 0;
    transition: color 0.15s, border-color 0.15s;
    z-index: 10;
  }

  .sidebar-close:hover {
    color: var(--text);
    border-color: var(--border-hi);
  }

  @media (max-width: 900px) {
    .sidebar-close { display: flex; }
    /* Give room for the close button above the nav */
    .sidebar-inner { padding-top: 3rem; }
  }

  /* ── Logo: hidden — identity lives in the header now ── */
  .logo { display: none; }

  /* ── Nav ── */
  .nav-section { margin-bottom: 1.75rem; }

  .section-label {
    font-family: var(--font-heading);
    font-size: 0.875rem;
    font-weight: 600;
    letter-spacing: -0.01em;
    color: var(--text);
    padding: 0 0.6rem 0.5rem;
    margin-bottom: 0.25rem;
  }

  .nav-link {
    display: block;
    font-family: var(--font-sans);
    font-size: 0.85rem;
    font-weight: 400;
    color: var(--text-muted);
    padding: 0.4rem 0.75rem;
    border-radius: 10px;
    letter-spacing: 0.01em;
    transition: all 0.15s ease;
    text-decoration: none;
  }

  .nav-link:hover {
    background: rgba(0, 0, 0, 0.04);
    color: var(--text);
    text-decoration: none;
  }

  .nav-link.active {
    background: var(--accent-bg);
    color: var(--accent);
    font-weight: 500;
  }

  .external-icon {
    font-size: 0.7rem;
    opacity: 0.5;
    margin-left: 0.15rem;
  }

  .agent-api-section {
    border-top: 1px solid var(--border);
    padding-top: 1.25rem;
    margin-top: 0.5rem;
  }

  .agent-api-section .section-label {
    font-size: 0.72rem;
    font-weight: 500;
    letter-spacing: 0.08em;
    color: var(--text-dim);
    padding: 0 0.6rem 0.5rem;
    margin-bottom: 0.25rem;
  }

  .api-link {
    font-family: var(--font-mono);
    font-size: 0.78rem;
    letter-spacing: 0;
    /* Shimmer gradient — terracotta → rose → indigo → teal → terracotta */
    background-image: linear-gradient(
      90deg,
      #C4571A 0%,
      #C45470 30%,
      #6B5CB8 55%,
      #2E8A7A 75%,
      #C4571A 100%
    );
    background-size: 250% 100%;
    background-position: 100% 0;
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
    color: transparent;
  }

  @media (prefers-reduced-motion: no-preference) {
    .api-link {
      animation: api-shimmer 8s linear infinite;
    }
  }

  @keyframes api-shimmer {
    0%   { background-position: 100% 0; }
    100% { background-position: -100% 0; }
  }

  .api-link:hover {
    background: rgba(0, 0, 0, 0.04);
    /* Override gradient on hover — restore solid muted color */
    background-image: none;
    -webkit-text-fill-color: var(--text-muted);
    color: var(--text-muted);
  }

  /* ── Drawer mode (≤ 900px) ── */
  @media (max-width: 900px) {
    .sidebar {
      display: flex; /* keep in DOM — visibility controlled via transform */
      top: 0;
      height: 100vh;
      transform: translateX(-100%);
      transition: transform 0.25s cubic-bezier(0.4, 0, 0.2, 1),
                  visibility 0.25s;
      visibility: hidden;
      z-index: 500;
      box-shadow: 4px 0 24px rgba(0, 0, 0, 0.12);
    }

    .sidebar.is-open {
      transform: translateX(0);
      visibility: visible;
    }
  }
</style>

<!-- Backdrop -->
<div class="sidebar-backdrop" id="sidebar-backdrop" aria-hidden="true"></div>

<style>
  .sidebar-backdrop {
    display: none;
    position: fixed;
    inset: 0;
    background: rgba(26, 26, 26, 0.35);
    backdrop-filter: blur(2px);
    -webkit-backdrop-filter: blur(2px);
    z-index: 490;
    opacity: 0;
    transition: opacity 0.25s ease;
  }

  @media (max-width: 900px) {
    .sidebar-backdrop.is-open {
      display: block;
      opacity: 1;
    }
  }
</style>

<script>
  const sidebar   = document.getElementById('sidebar') as HTMLElement | null;
  const backdrop  = document.getElementById('sidebar-backdrop') as HTMLElement | null;
  const hamburger = document.getElementById('sidebar-hamburger') as HTMLButtonElement | null;
  const closeBtn  = document.getElementById('sidebar-close') as HTMLButtonElement | null;

  function openSidebar() {
    if (!sidebar || !backdrop || !hamburger) return;
    sidebar.classList.add('is-open');
    backdrop.classList.add('is-open');
    hamburger.setAttribute('aria-expanded', 'true');
    sidebar.removeAttribute('aria-hidden');
    // focus first focusable element inside drawer
    const firstLink = sidebar.querySelector<HTMLElement>('a, button');
    firstLink?.focus();
  }

  function closeSidebar() {
    if (!sidebar || !backdrop || !hamburger) return;
    sidebar.classList.remove('is-open');
    backdrop.classList.remove('is-open');
    hamburger.setAttribute('aria-expanded', 'false');
    sidebar.setAttribute('aria-hidden', 'true');
    hamburger.focus();
  }

  // Set initial aria-hidden based on viewport
  function syncInitialState() {
    if (!sidebar || !hamburger) return;
    if (window.innerWidth <= 900) {
      sidebar.setAttribute('aria-hidden', 'true');
    } else {
      sidebar.removeAttribute('aria-hidden');
    }
  }
  syncInitialState();
  window.addEventListener('resize', syncInitialState);

  hamburger?.addEventListener('click', () => {
    const isOpen = sidebar?.classList.contains('is-open');
    isOpen ? closeSidebar() : openSidebar();
  });

  backdrop?.addEventListener('click', closeSidebar);
  closeBtn?.addEventListener('click', closeSidebar);

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && sidebar?.classList.contains('is-open')) {
      closeSidebar();
    }
  });

  // Close on nav link click (navigate + close)
  sidebar?.querySelectorAll('.nav-link').forEach((link) => {
    link.addEventListener('click', () => {
      if (window.innerWidth <= 900) closeSidebar();
    });
  });

  // Simple focus trap inside drawer
  sidebar?.addEventListener('keydown', (e) => {
    if (e.key !== 'Tab' || !sidebar.classList.contains('is-open')) return;
    const focusable = Array.from(
      sidebar.querySelectorAll<HTMLElement>('a[href], button, [tabindex]:not([tabindex="-1"])')
    ).filter(el => !el.hasAttribute('disabled'));
    if (focusable.length === 0) return;
    const first = focusable[0];
    const last  = focusable[focusable.length - 1];
    if (e.shiftKey && document.activeElement === first) {
      e.preventDefault();
      last.focus();
    } else if (!e.shiftKey && document.activeElement === last) {
      e.preventDefault();
      first.focus();
    }
  });
</script>
