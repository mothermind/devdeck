    .commit-btn-save {
      font-size: 7.5px;
      font-family: var(--font-sans);
      font-weight: 600;
      padding: 3px 12px;
      border-radius: 4px;
      border: none;
      background: #217346;
      color: #fff;
      cursor: default;
      transition: background 0.15s, transform 0.1s;
    }

    .commit-btn-save.clicked { background: #1a5c38; transform: scale(0.95); }

    .commit-wb .wb-cell.has-data {
      font-size: 9px;
      font-family: var(--font-sans);
      color: #333;
      display: flex;
      align-items: center;
      padding-left: 3px;
    }

    .commit-wb .wb-status.saved span {
      color: #217346;
    }

    /* Right-side version files */
    .commit-files {
      position: absolute;
      left: 490px;
      top: 90px;
      width: 180px;
      display: flex;
      flex-direction: column;
      gap: 14px;
    }

    .commit-file {
      display: flex;
      align-items: center;
      gap: 10px;
    }

    .commit-file-icon {
      width: 40px;
      height: 48px;
      background: #fff;
      border: 1.5px solid #217346;
      border-radius: 5px;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      box-shadow: 0 2px 8px rgba(0,0,0,0.2);
      flex-shrink: 0;
    }

    .commit-file-icon span {
      font-size: 16px;
      color: #217346;
      font-weight: 700;
      font-family: var(--font-sans);
      line-height: 1;
    }

    .commit-file-icon small {
      font-size: 5.5px;
      color: #666;
      font-family: var(--font-mono);
    }

    .commit-file-name {
      font-family: var(--font-mono);
      font-size: 11px;
      color: #ccc;
