      color: #777;
      margin-top: 2px;
    }

    .commit-file.new-file {
      opacity: 0;
      transform: translateY(-8px);
      transition: opacity 0.4s ease, transform 0.4s ease;
    }

    .commit-file.new-file.show {
      opacity: 1;
      transform: translateY(0);
    }

    .commit-file.new-file .commit-file-icon {
      border-color: #2da44e;
    }

    .commit-file.new-file .commit-file-icon span {
      color: #2da44e;
    }

    .commit-file.new-file .commit-file-name {
      color: #2da44e;
    }

    /* --- Animation: git status --- */
    .anim-status {
      width: 780px;
      height: 380px;
    }

    .status-wb {
      position: absolute;
      left: 38%; top: 50%;
      transform: translate(-50%, -50%);
      width: 480px; height: 340px;
      background: #fff;
      border-radius: 10px;
      overflow: hidden;
      box-shadow: 0 8px 40px rgba(0,0,0,0.5);
      display: flex;
      flex-direction: column;
    }

    .status-wb .wb-cell {
      width: 72px;
      height: 24px;
    }

    .status-wb .wb-colh div {
      width: 72px;
    }

    .status-wb .wb-cells .wb-row {
      height: 24px;
    }

    .status-wb .wb-cell.has-data {
      font-size: 10px;
      font-family: var(--font-sans);
      color: #333;
      display: flex;
      align-items: center;
      padding-left: 4px;
    }

    /* Cell state colors */
    .status-wb .wb-cell.modified {
      background: #ffebee;
      position: relative;
    }

    .status-wb .wb-cell.modified::after {
      content: '';
      position: absolute;
      top: 2px; right: 2px;
      width: 5px; height: 5px;
      border-radius: 50%;
      background: #e53935;
    }

    .status-wb .wb-cell.modified.has-data {
      color: #c62828;
      font-weight: 600;
    }

    .status-wb .wb-cell.staged {
      background: #e8f5e9;
      position: relative;
    }

    .status-wb .wb-cell.staged::after {
      content: '';
      position: absolute;
      top: 2px; right: 2px;
      width: 5px; height: 5px;
      border-radius: 50%;
      background: #2da44e;
    }

    .status-wb .wb-cell.staged.has-data {
      color: #2da44e;
      font-weight: 600;
    }

    .status-wb .wb-cell.untracked {
      background: #fff3e0;
    }

    .status-wb .wb-cell.untracked.has-data {
      color: #e65100;
      font-weight: 600;
    }

    /* Hidden state for animation reveal */
    .status-wb .wb-cell.modified.hidden,
    .status-wb .wb-cell.staged.hidden,
    .status-wb .wb-cell.untracked.hidden {
      background: #fff;
      transition: background 0.4s ease, color 0.3s ease;
    }

    .status-wb .wb-cell.modified.hidden.has-data,
    .status-wb .wb-cell.staged.hidden.has-data,
    .status-wb .wb-cell.untracked.hidden.has-data {
      color: #333;
      font-weight: normal;
    }

    .status-wb .wb-cell.modified.hidden::after,
    .status-wb .wb-cell.staged.hidden::after {
      opacity: 0;
      transition: opacity 0.3s ease;
    }

    /* Legend (right side) */
    .status-legend {
      position: absolute;
      left: 580px;
      top: 100px;
      display: flex;
      flex-direction: column;
      gap: 16px;
    }

    .status-legend-item {
      display: flex;
      align-items: center;
      gap: 8px;
      font-size: 12px;
      color: #bbb;
      font-family: var(--font-sans);
      white-space: nowrap;
      opacity: 0;
      transform: translateX(-8px);
      transition: opacity 0.5s ease, transform 0.5s ease;
    }

    .status-legend-item.show {
      opacity: 1;
      transform: translateX(0);
    }

    .status-swatch {
      width: 12px; height: 12px;
      border-radius: 3px;
      flex-shrink: 0;
    }

    .status-swatch.modified-sw { background: #e53935; }
    .status-swatch.staged-sw { background: #2da44e; }
    .status-swatch.untracked-sw { background: #ffa726; }
    .status-swatch.clean-sw { background: #fff; border: 1px solid #999; }


    /* --- Animation: git diff --- */
    .anim-diff {
      width: 780px;
      height: 380px;
    }

    .diff-wb {
      position: absolute;
      left: 38%; top: 50%;
      transform: translate(-50%, -50%);
      width: 480px; height: 340px;
      background: #fff;
      border-radius: 10px;
      overflow: hidden;
      box-shadow: 0 8px 40px rgba(0,0,0,0.5);
      display: flex;
      flex-direction: column;
    }

    .diff-wb .wb-cell {
      width: 72px;
      height: 24px;
    }

    .diff-wb .wb-colh div {
      width: 72px;
    }

    .diff-wb .wb-cells .wb-row {
      height: 24px;
    }

    .diff-wb .wb-cell.has-data {
      font-size: 10px;
      font-family: var(--font-sans);
      color: #333;
      display: flex;
      align-items: center;
      padding-left: 4px;
    }


    /* Changed cells: old→new inline */
    .diff-wb .wb-cell.diff-changed {
      background: #fff;
      position: relative;
      transition: background 0.4s ease;
    }

    .diff-wb .wb-cell.diff-changed.reveal {
      background: #ffebee;
    }

    .diff-old {
      text-decoration: line-through;
      color: #c62828;
      font-size: 10px;
      opacity: 0;
      transition: opacity 0.4s ease;
    }

    .diff-changed.reveal .diff-old {
      opacity: 1;
    }

    .diff-arrow {
      color: #999;
      font-size: 10px;
      margin: 0 2px;
      opacity: 0;
      transition: opacity 0.4s ease;
    }

    .diff-changed.reveal .diff-arrow {
      opacity: 1;
    }

    .diff-new {
      color: #2e7d32;
      font-weight: 600;
      font-size: 10px;
      opacity: 0;
      transition: opacity 0.4s ease;
    }

    .diff-changed.reveal .diff-new {
      opacity: 1;
    }

    /* Initially show plain value, hide diff parts */
    .diff-wb .wb-cell.diff-changed.has-data {
      color: #333;
    }

    /* Added row */
    .diff-wb .wb-cell.diff-added {
      background: #fff;
      transition: background 0.4s ease, color 0.3s ease;
    }

    .diff-wb .wb-cell.diff-added.reveal {
      background: #e8f5e9;
      color: #2e7d32;
      font-weight: 600;
    }

    /* Legend (right side) */
    .diff-legend {
      position: absolute;
      left: 580px;
      top: 120px;
      display: flex;
      flex-direction: column;
      gap: 16px;
    }

    .diff-legend-item {
      display: flex;
      align-items: center;
      gap: 8px;
      font-size: 12px;
      color: #bbb;
      font-family: var(--font-sans);
      white-space: nowrap;
      opacity: 0;
      transform: translateX(-8px);
      transition: opacity 0.5s ease, transform 0.5s ease;
    }

    .diff-legend-item.show {
      opacity: 1;
      transform: translateX(0);
    }

    /* --- Animation: git log --- */
    .anim-log {
      width: 520px;
      height: 340px;
    }

    .log-finder {
      position: absolute;
      left: 50%; top: 50%;
      transform: translate(-50%, -50%);
      width: 480px;
      background: #fff;
      border-radius: 10px;
      overflow: hidden;
      box-shadow: 0 8px 40px rgba(0,0,0,0.5);
      display: flex;
