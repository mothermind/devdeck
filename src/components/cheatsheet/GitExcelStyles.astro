    .clone-dicon-name {
      font-size: 6.5px;
      color: #333;
      font-family: var(--font-sans);
      text-shadow: 0 1px 2px rgba(255,255,255,0.3);
      margin-top: 2px;
    }

    /* The file that lands on the desktop */
    .clone-dfile {
      position: absolute;
      left: 80px;
      top: 20px;
      display: flex;
      flex-direction: column;
      align-items: center;
      opacity: 0;
      transform: scale(0.4) translateY(-30px);
      transition: opacity 0.5s ease, transform 0.5s cubic-bezier(0.34, 1.56, 0.64, 1);
    }

    .clone-dfile.landed {
      opacity: 1;
      transform: scale(1) translateY(0);
    }

    .clone-dfile-icon {
      width: 34px;
      height: 40px;
      background: #fff;
      border: 1.5px solid #217346;
      border-radius: 4px;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      box-shadow: 0 3px 12px rgba(0,0,0,0.35);
    }

    .clone-dfile-icon span {
      font-size: 14px;
      color: #217346;
      font-weight: 700;
      font-family: var(--font-sans);
      line-height: 1;
    }

    .clone-dfile-icon small {
      font-size: 5px;
      color: #666;
      font-family: var(--font-mono);
