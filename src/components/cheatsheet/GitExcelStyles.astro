      align-items: center;
      padding: 0 12px;
    }

    .log-statusbar span {
      font-size: 9px;
      color: #999;
      font-family: var(--font-sans);
    }

    /* --- Animation: git clone --- */
    .anim-clone {
      width: 460px;
      height: 340px;
    }

    /* The single monitor */
    .clone-mon {
      position: absolute;
      left: 50%;
      top: 0;
      transform: translateX(-50%);
      width: 440px;
      opacity: 0;
      animation: fadeIn 0.5s ease 0.3s forwards;
    }

    .clone-mon-bezel {
      width: 100%;
      height: 310px;
      background: #222;
      border-radius: 10px;
      border: 2px solid #333;
      overflow: hidden;
      position: relative;
    }

    /* Screen content area */
    .clone-screen {
      width: 100%;
      height: 100%;
      position: relative;
    }

    /* Web view layer */
    .clone-web {
      position: absolute;
      inset: 0;
      background: #fff;
      transition: opacity 0.5s ease;
      z-index: 2;
    }

    .clone-web.fade-out { opacity: 0; z-index: 0; }

    .clone-web-bar {
      height: 24px;
      background: #e8e8e8;
      display: flex;
      align-items: center;
      padding: 0 8px;
      gap: 6px;
      border-bottom: 1px solid #ccc;
    }

    .clone-web-dots { display: flex; gap: 4px; }
    .clone-web-dot { width: 8px; height: 8px; border-radius: 50%; }
    .clone-web-dot.r { background: #ff5f57; }
    .clone-web-dot.y { background: #ffbd2e; }
    .clone-web-dot.g { background: #28c940; }

    .clone-web-url {
      flex: 1;
      height: 15px;
      background: #fff;
      border: 1px solid #ccc;
      border-radius: 3px;
      display: flex;
      align-items: center;
      padding: 0 6px;
      font-family: var(--font-mono);
      font-size: 7.5px;
      color: #555;
    }

    .clone-web-lock { color: #2da44e; margin-right: 3px; font-size: 8px; }

    .clone-web-body {
      padding: 20px 24px;
    }

    .clone-web-hdr {
      display: flex;
      align-items: center;
      gap: 8px;
      margin-bottom: 12px;
    }

    .clone-web-ficon {
      width: 28px;
      height: 28px;
      background: #217346;
      border-radius: 4px;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 14px;
      color: #fff;
      font-weight: 700;
      font-family: var(--font-sans);
    }

    .clone-web-fname {
      font-family: var(--font-sans);
      font-size: 13px;
      font-weight: 600;
      color: #1a1a1a;
    }

    .clone-web-meta {
      font-family: var(--font-sans);
      font-size: 9px;
      color: #888;
      margin-bottom: 16px;
      line-height: 1.5;
    }

    .clone-dl-btn {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      background: #217346;
      color: #fff;
      border: none;
      border-radius: 6px;
      padding: 8px 18px;
      font-family: var(--font-sans);
      font-size: 11px;
      font-weight: 600;
      cursor: default;
      transition: background 0.15s, transform 0.1s;
    }

    .clone-dl-btn.clicked { background: #1a5c38; transform: scale(0.97); }
    .clone-dl-btn svg { flex-shrink: 0; }

    /* Desktop view layer (behind web, revealed on fade) */
    .clone-desk {
      position: absolute;
      inset: 0;
      z-index: 1;
    }

    .clone-desk-menubar {
      height: 18px;
      background: rgba(240, 240, 240, 0.85);
      backdrop-filter: blur(8px);
      display: flex;
      align-items: center;
      padding: 0 8px;
      justify-content: space-between;
      border-bottom: 1px solid #d0d0d0;
    }

    .clone-desk-menu-l {
      display: flex;
      gap: 8px;
      font-size: 7.5px;
      color: #333;
      font-family: var(--font-sans);
      font-weight: 500;
    }

    .clone-desk-menu-r {
      font-size: 7.5px;
      color: #555;
      font-family: var(--font-mono);
    }

    .clone-desk-area {
      position: relative;
      height: calc(100% - 18px);
      background: linear-gradient(135deg, #b8cce4 0%, #a3c1e0 30%, #c9b8d9 70%, #d4a8c8 100%);
      overflow: hidden;
    }

    /* Folder on the desktop */
    .clone-dfolder {
      position: absolute;
      left: 20px;
      top: 24px;
      display: flex;
      flex-direction: column;
      align-items: center;
    }

    .clone-dfolder-icon {
      width: 44px;
      height: 36px;
      position: relative;
    }

    .clone-dfolder-tab {
