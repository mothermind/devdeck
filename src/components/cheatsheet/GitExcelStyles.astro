      background: #4a9de8;
      border-radius: 3px 3px 0 0;
    }

    .clone-dfolder-body {
      position: absolute;
      bottom: 0; left: 0;
      width: 44px;
      height: 28px;
      background: #60b1f7;
      border-radius: 0 5px 5px 5px;
    }

    .clone-dfolder-name {
      font-size: 7px;
      color: #333;
      font-family: var(--font-sans);
      text-shadow: 0 1px 2px rgba(255,255,255,0.4);
      margin-top: 3px;
    }

    /* Desktop icons right side */
    .clone-dicons {
      position: absolute;
      right: 14px;
      top: 20px;
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 10px;
    }

    .clone-dicon {
      display: flex;
      flex-direction: column;
      align-items: center;
    }

    .clone-dicon-img {
      width: 30px;
      height: 30px;
      border-radius: 6px;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 15px;
