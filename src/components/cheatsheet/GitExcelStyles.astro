    }

    .log-titlebar {
      height: 28px;
      background: #e8e8e8;
      display: flex;
      align-items: center;
      padding: 0 10px;
      flex-shrink: 0;
    }

    .log-dots {
      display: flex;
      gap: 5px;
    }

    .log-title {
      flex: 1;
      text-align: center;
