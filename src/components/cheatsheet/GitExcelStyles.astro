---
// All CSS for the Git for Excel People cheatsheet page
---
  <style is:inline>
    /* ═══════════════════════════════════════════
       DESIGN TOKENS (from STYLE_GUIDE.md)
       ═══════════════════════════════════════════ */
    :root {
      --bg: #FAF6F0;
      --surface: #F0EBE3;
      --sidebar-bg: #EDE8E0;
      --border: #D5CEC4;
      --border-hi: #C4BBB0;
      --text: #1A1A1A;
      --text-muted: #555555;
      --text-dim: #888888;
      --accent: #D4620A;
      --accent-bg: rgba(212,98,10,0.08);
      --code-bg: #1A1A1A;
      --code-text: #E8E8E8;
      --font-heading: 'DM Sans', -apple-system, system-ui, sans-serif;
      --font-sans: 'DM Sans', ui-monospace, system-ui, sans-serif;
      --font-mono: 'JetBrains Mono', SF Mono, ui-monospace, Menlo, monospace;
      --header-h: 0px;
      --sidebar-w: 220px;
    }

    * { margin: 0; padding: 0; box-sizing: border-box; }

    html {
      scroll-behavior: smooth;
      scroll-padding-top: 24px;
    }

    body {
      font-family: var(--font-sans);
      font-size: 15px;
      line-height: 1.8;
      color: var(--text-muted);
      background: var(--bg);
    }

    /* ═══════════════════════════════════════════
       SIDEBAR
       ═══════════════════════════════════════════ */
    .sidebar {
      position: fixed;
      top: 0;
      left: 0;
      width: var(--sidebar-w);
      height: 100vh;
      background: var(--sidebar-bg);
      border-right: 1px solid var(--border);
      display: flex;
      flex-direction: column;
      z-index: 100;
      transition: transform 0.3s ease;
    }

    .sidebar-header {
      padding: 20px 18px 16px;
      border-bottom: 1px solid var(--border);
      display: flex;
      align-items: center;
      justify-content: space-between;
    }

    .sidebar-brand {
      font-family: 'Fredoka', var(--font-heading);
      font-size: 0.95rem;
      font-weight: 600;
      color: var(--text);
      letter-spacing: -0.01em;
    }

    .sidebar-brand small {
      display: block;
      font-family: var(--font-sans);
      font-size: 0.68rem;
      font-weight: 500;
      color: var(--text-dim);
      letter-spacing: 0.04em;
      margin-top: 2px;
    }

    .sidebar-collapse-btn {
      width: 28px;
      height: 28px;
      display: flex;
      align-items: center;
      justify-content: center;
      background: none;
      border: 1px solid var(--border);
      border-radius: 6px;
      color: var(--text-dim);
      cursor: pointer;
      font-size: 14px;
      transition: all 0.15s;
    }

    .sidebar-collapse-btn:hover {
      border-color: var(--accent);
      color: var(--accent);
    }

    .sidebar-nav {
      flex: 1;
      padding: 12px 10px;
      overflow-y: auto;
    }

    .sidebar-nav::-webkit-scrollbar { width: 3px; }
    .sidebar-nav::-webkit-scrollbar-thumb { background: var(--border); border-radius: 3px; }

    .nav-link {
      display: flex;
      align-items: center;
      gap: 10px;
      padding: 0.4rem 0.75rem;
      border-radius: 10px;
      font-family: var(--font-sans);
      font-size: 0.85rem;
      font-weight: 400;
      color: var(--text-muted);
      text-decoration: none;
      transition: all 0.15s ease;
      letter-spacing: 0.01em;
      cursor: pointer;
      margin-bottom: 2px;
    }

    .nav-link:hover {
      background: rgba(0,0,0,0.04);
    }

    .nav-link.active {
      background: var(--accent-bg);
      color: var(--accent);
      font-weight: 500;
    }

    .nav-link .nav-dot {
      width: 6px;
      height: 6px;
      border-radius: 50%;
      background: transparent;
      flex-shrink: 0;
      transition: background 0.15s;
    }

    .nav-link.active .nav-dot {
      background: var(--accent);
    }

    .nav-divider {
      height: 1px;
      background: var(--border);
      margin: 10px 12px;
    }

    .nav-link.secondary {
      font-size: 0.8rem;
      color: var(--text-dim);
    }

    .nav-link.secondary.active {
      color: var(--accent);
    }

    /* Mobile toggle */
    .mobile-toggle {
      display: none;
      position: fixed;
      top: 12px;
      left: 12px;
      z-index: 200;
      width: 40px;
      height: 40px;
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: 10px;
      align-items: center;
      justify-content: center;
      cursor: pointer;
      font-size: 18px;
      color: var(--text-muted);
    }

    .sidebar-overlay {
      display: none;
      position: fixed;
      inset: 0;
      background: rgba(0,0,0,0.2);
      z-index: 90;
    }

    /* ═══════════════════════════════════════════
       MAIN CONTENT
       ═══════════════════════════════════════════ */
    .main {
      margin-left: var(--sidebar-w);
      min-height: 100vh;
    }

    /* Panic bar */
    .panic-bar {
      position: sticky;
      top: 0;
      z-index: 50;
      background: rgba(250,246,240,0.92);
      backdrop-filter: blur(12px);
      -webkit-backdrop-filter: blur(12px);
      border-bottom: 1px solid var(--border);
      padding: 12px 40px;
    }

    .panic-input-wrap {
      position: relative;
      max-width: 560px;
    }

    .panic-icon {
      position: absolute;
      left: 14px;
      top: 50%;
      transform: translateY(-50%);
      color: var(--text-dim);
      font-size: 15px;
      pointer-events: none;
    }

    .panic-input {
      width: 100%;
      padding: 10px 14px 10px 40px;
      font-family: var(--font-sans);
      font-size: 0.9rem;
      color: var(--text);
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: 10px;
      outline: none;
      transition: border-color 0.15s;
    }

    .panic-input::placeholder {
      color: var(--text-dim);
    }

    .panic-input:focus {
      border-color: var(--accent);
    }

    .panic-clear {
      position: absolute;
      right: 10px;
      top: 50%;
      transform: translateY(-50%);
      background: none;
      border: none;
      color: var(--text-dim);
      cursor: pointer;
      font-size: 16px;
      display: none;
      padding: 4px;
    }

    .panic-clear.show { display: block; }

    .panic-results {
      position: absolute;
      top: calc(100% + 6px);
      left: 0;
      right: 0;
      background: var(--bg);
      border: 1px solid var(--border);
      border-radius: 12px;
      box-shadow: 0 8px 32px rgba(0,0,0,0.1);
      max-height: 360px;
      overflow-y: auto;
      display: none;
      z-index: 60;
    }

    .panic-results.show { display: block; }

    .panic-result {
      display: flex;
      align-items: baseline;
      gap: 12px;
      padding: 10px 16px;
      cursor: pointer;
      transition: background 0.15s;
      text-decoration: none;
      color: inherit;
    }

    .panic-result:hover {
      background: rgba(0,0,0,0.04);
    }

    .panic-result-cmd {
      font-family: var(--font-mono);
      font-size: 0.82rem;
      font-weight: 500;
      color: var(--text);
      background: rgba(0,0,0,0.05);
      border: 1px solid var(--border);
      border-radius: 6px;
      padding: 0.1em 0.45em;
      white-space: nowrap;
    }

    .panic-result-desc {
      font-size: 0.82rem;
      color: var(--text-dim);
    }

    .panic-no-results {
      padding: 16px;
      text-align: center;
      color: var(--text-dim);
      font-size: 0.85rem;
    }

    /* Content sections */
    .content {
      max-width: 900px;
      padding: 32px 40px 120px;
    }

    section {
      margin-bottom: 3.5rem;
    }

    section h2 {
      font-family: 'Fredoka', var(--font-heading);
      font-size: 1.375rem;
      font-weight: 600;
      letter-spacing: -0.01em;
      color: var(--text);
      margin-bottom: 0.5rem;
    }

    section .section-intro {
      font-size: 0.92rem;
      color: var(--text-dim);
      margin-bottom: 1.5rem;
      max-width: 640px;
    }

    /* Command cards */
    .cmd-card {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: 12px;
      padding: 1.25rem 1.5rem;
      margin-bottom: 0.75rem;
      transition: border-color 0.15s;
    }

    .cmd-card:hover {
      border-color: var(--border-hi);
    }

    .cmd-card-header {
      display: flex;
      align-items: baseline;
      gap: 12px;
      margin-bottom: 0.4rem;
      flex-wrap: wrap;
    }

    .cmd-name {
      font-family: var(--font-mono);
      font-size: 0.88rem;
      font-weight: 500;
      color: var(--text);
      background: rgba(0,0,0,0.05);
      border: 1px solid var(--border);
      border-radius: 6px;
      padding: 0.15em 0.55em;
    }


    .cmd-desc {
      font-size: 0.85rem;
      color: var(--text-muted);
    }

    .cmd-analogy {
      display: flex;
      align-items: baseline;
      gap: 8px;
      font-size: 0.84rem;
      color: #b5520a;
      margin-top: 0.35rem;
      padding-top: 0.5rem;
      border-top: 1px solid rgba(0,0,0,0.06);
    }

    .cmd-analogy-label {
      font-family: var(--font-mono);
      font-size: 0.68rem;
      font-weight: 500;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: var(--accent);
      background: var(--accent-bg);
      border: 1px solid rgba(212,98,10,0.25);
      border-radius: 6px;
      padding: 0.18rem 0.6rem;
      white-space: nowrap;
      flex-shrink: 0;
    }

    /* Concept cards (Key Concepts) */
    .concept-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
      gap: 0.75rem;
    }

    .concept-card {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: 12px;
      padding: 1rem 1.25rem;
    }

    .concept-card .concept-term {
      font-family: var(--font-mono);
      font-size: 0.82rem;
      font-weight: 500;
      color: var(--text);
      margin-bottom: 0.25rem;
    }

    .concept-card .concept-meaning {
      font-size: 0.82rem;
      color: var(--text-muted);
      margin-bottom: 0.5rem;
    }

    .concept-card .concept-excel {
      font-size: 0.78rem;
      color: #b5520a;
      border-top: 1px solid rgba(0,0,0,0.06);
      padding-top: 0.4rem;
    }

    /* Cheatsheet table */
    .cheatsheet-table {
      width: 100%;
      border-collapse: collapse;
    }

    .cheatsheet-table th {
      font-size: 0.68rem;
      font-weight: 500;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: var(--text-dim);
      border-bottom: 1px solid var(--border);
      padding: 0.5rem 0.75rem;
      text-align: left;
    }

    .cheatsheet-table td {
      padding: 0.5rem 0.75rem;
      border-bottom: 1px solid rgba(0,0,0,0.06);
      color: var(--text-muted);
      font-size: 0.85rem;
      vertical-align: top;
    }

    .cheatsheet-table td:first-child {
      color: var(--text);
      font-family: var(--font-mono);
      font-size: 0.8rem;
      white-space: nowrap;
    }

    .cheatsheet-table td:last-child {
      color: #b5520a;
    }

    .cheatsheet-table tr:hover td {
      background: rgba(0,0,0,0.03);
    }

    .cheatsheet-table .table-group-header td {
      font-family: var(--font-heading);
      font-size: 0.75rem;
      font-weight: 600;
      color: var(--text);
      letter-spacing: 0.02em;
      padding-top: 1.2rem;
      border-bottom: 1px solid var(--border);
      background: none !important;
    }

    /* Section labels */
    .section-label {
      font-size: 0.68rem;
      font-weight: 500;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: var(--text-dim);
      margin-bottom: 1rem;
    }

    /* Note / callout */
    .callout {
      border-left: 3px solid rgba(212,98,10,0.3);
      background: rgba(212,98,10,0.04);
      border-radius: 0 8px 8px 0;
      padding: 0.65rem 1.1rem;
      font-size: 0.85rem;
      color: var(--text-dim);
      font-style: italic;
      margin: 1rem 0;
    }

    /* Stories section */
    .story-card {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: 12px;
      padding: 1.5rem;
      margin-bottom: 1rem;
    }

    .story-card h4 {
      font-family: var(--font-heading);
      font-size: 1rem;
      font-weight: 600;
      color: var(--text);
      margin-bottom: 0.75rem;
    }

    .story-step {
      display: flex;
      gap: 12px;
      margin-bottom: 0.6rem;
      align-items: baseline;
    }

    .story-num {
      font-family: var(--font-mono);
      font-size: 0.72rem;
      font-weight: 500;
      color: var(--accent);
      background: var(--accent-bg);
      border-radius: 50%;
      width: 22px;
      height: 22px;
      display: flex;
      align-items: center;
      justify-content: center;
      flex-shrink: 0;
    }

    .story-text {
      font-size: 0.85rem;
      color: var(--text-muted);
    }

    .story-text code {
      font-family: var(--font-mono);
      font-size: 0.82em;
      font-weight: 500;
      background: rgba(0,0,0,0.05);
      border: 1px solid var(--border);
      border-radius: 6px;
      padding: 0.1em 0.45em;
      color: var(--text);
    }

    .story-excel {
      font-size: 0.82rem;
      color: #b5520a;
      margin-top: 0.75rem;
      padding-top: 0.75rem;
      border-top: 1px solid rgba(0,0,0,0.06);
    }

    /* ═══════════════════════════════════════════
       ANIMATIONS
       ═══════════════════════════════════════════ */
    .anim-container {
      background: var(--code-bg);
      border: 1px solid rgba(0,0,0,0.12);
      border-radius: 12px;
      padding: 24px;
      margin: 1rem 0;
      display: flex;
      flex-direction: column;
      align-items: center;
    }


    .anim-stage {
      position: relative;
    }

    .replay-btn {
      margin-top: 16px;
      font-size: 1.1rem;
      color: var(--text-dim);
      background: none;
      border: 1px solid #444;
      border-radius: 50%;
      width: 32px;
      height: 32px;
      display: flex;
      align-items: center;
      justify-content: center;
      cursor: pointer;
      transition: border-color 0.15s, color 0.15s;
    }

    .replay-btn:hover {
      border-color: var(--accent);
      color: var(--accent);
    }

    /* --- Animation 1: New Workbook --- */
    .anim-wb {
      width: 420px;
      height: 300px;
    }

    .wb-window {
      position: absolute;
      left: 50%; top: 50%;
      width: 0; height: 0;
      opacity: 0;
      transform: translate(-50%,-50%) scale(0.3);
      background: #fff;
      border-radius: 6px;
      overflow: hidden;
      box-shadow: 0 8px 40px rgba(0,0,0,0.5);
      animation: wbOpen 1s ease-out 0.5s forwards;
      display: flex;
      flex-direction: column;
    }

    @keyframes wbOpen {
      0%   { width: 0; height: 0; opacity: 0; transform: translate(-50%,-50%) scale(0.3); }
      30%  { opacity: 1; }
      100% { width: 400px; height: 280px; opacity: 1; transform: translate(-50%,-50%) scale(1); }
    }

    .wb-titlebar {
      height: 28px;
      background: #217346;
      display: flex;
      align-items: center;
      padding: 0 10px;
      flex-shrink: 0;
    }

    .wb-dots { display: flex; gap: 5px; }

    .wb-dot {
      width: 10px; height: 10px;
      border-radius: 50%;
      opacity: 0;
      animation: fadeIn 0.3s ease forwards;
    }

    .wb-dot.r { background: #ff5f57; animation-delay: 1.5s; }
    .wb-dot.y { background: #ffbd2e; animation-delay: 1.6s; }
    .wb-dot.g { background: #28c940; animation-delay: 1.7s; }

    .wb-title {
      flex: 1;
      text-align: center;
      color: #fff;
      font-size: 11px;
      font-weight: 600;
      font-family: var(--font-sans);
      opacity: 0;
      animation: fadeIn 0.3s ease 1.3s forwards;
    }

    .wb-ribbon {
      height: 22px;
      background: #217346;
      border-bottom: 2px solid #1a5c38;
      display: flex;
      align-items: center;
      padding: 0 10px;
      gap: 12px;
      flex-shrink: 0;
    }

    .wb-ribbon span {
      font-size: 10px;
      color: #c8e6c9;
      font-family: var(--font-sans);
      opacity: 0;
      animation: fadeIn 0.3s ease forwards;
    }

    .wb-ribbon span:nth-child(1) { animation-delay: 1.8s; }
    .wb-ribbon span:nth-child(2) { animation-delay: 1.85s; }
    .wb-ribbon span:nth-child(3) { animation-delay: 1.9s; }
    .wb-ribbon span:nth-child(4) { animation-delay: 1.95s; }
    .wb-ribbon span:nth-child(5) { animation-delay: 2.0s; }

    .wb-formula {
      height: 20px;
      background: #f5f5f5;
      border-bottom: 1px solid #d0d0d0;
      display: flex;
      align-items: center;
      padding: 0 8px;
      gap: 6px;
      flex-shrink: 0;
      opacity: 0;
      animation: fadeIn 0.3s ease 1.7s forwards;
    }

    .wb-formula span {
      font-size: 10px;
      color: #555;
      font-family: var(--font-mono);
    }

    .wb-grid-area {
      flex: 1;
      display: flex;
      background: #fff;
      opacity: 0;
      animation: fadeIn 0.3s ease 1.5s forwards;
      overflow: hidden;
    }

    .wb-rowh {
      width: 28px;
      background: #f0f0f0;
      border-right: 1px solid #ccc;
    }

    .wb-rowh div {
      height: 20px;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 9px;
      color: #777;
      font-family: var(--font-mono);
      border-bottom: 1px solid #ddd;
    }

    .wb-grid-inner { flex: 1; overflow: hidden; }

    .wb-colh {
      display: flex;
      background: #f0f0f0;
      border-bottom: 1px solid #ccc;
      height: 18px;
    }

    .wb-colh div {
      width: 60px;
      text-align: center;
      font-size: 9px;
      color: #777;
      line-height: 18px;
      font-family: var(--font-mono);
      border-right: 1px solid #ddd;
    }

    .wb-cells .wb-row { display: flex; height: 20px; }

    .wb-cell {
      width: 60px;
      height: 20px;
      border-right: 1px solid #e8e8e8;
      border-bottom: 1px solid #e8e8e8;
    }

    .wb-cell.active-cell {
      outline: 2px solid #217346;
      outline-offset: -1px;
      opacity: 0;
      animation: fadeIn 0.3s ease 2.2s forwards;
      position: relative;
    }

    .wb-cursor-blink {
      position: absolute;
      top: 2px; left: 2px;
      width: 1px; height: 14px;
      background: #333;
      opacity: 0;
      animation: fadeIn 0.1s ease 2.4s forwards, blinkCur 1s step-end 2.4s infinite;
    }

    .wb-tabs {
      height: 20px;
      background: #e8e8e8;
      display: flex;
      align-items: center;
      padding: 0 8px;
      border-top: 1px solid #ccc;
      flex-shrink: 0;
      opacity: 0;
      animation: fadeIn 0.3s ease 2.0s forwards;
    }

    .wb-tab {
      font-size: 10px;
      color: #333;
      font-family: var(--font-sans);
      background: #fff;
      padding: 1px 12px;
      border: 1px solid #ccc;
      border-bottom: none;
      border-radius: 3px 3px 0 0;
      font-weight: 600;
    }

    .wb-status {
      height: 16px;
      background: #217346;
      flex-shrink: 0;
      display: flex;
      align-items: center;
      padding: 0 8px;
    }

    .wb-status span {
      font-size: 9px;
      color: #c8e6c9;
      font-family: var(--font-sans);
      opacity: 0;
      animation: fadeIn 0.3s ease 2.2s forwards;
    }

    @keyframes fadeIn { to { opacity: 1; } }
    @keyframes blinkCur { 0%,100% { opacity:1; } 50% { opacity:0; } }

    /* --- Animation: git commit --- */
    .anim-commit {
      width: 680px;
      height: 300px;
    }

    .commit-wb {
      position: absolute;
      left: 38%; top: 50%;
      width: 400px; height: 280px;
      transform: translate(-50%,-50%);
      background: #fff;
      border-radius: 10px;
      overflow: hidden;
      box-shadow: 0 8px 40px rgba(0,0,0,0.5);
      display: flex;
      flex-direction: column;
    }

    /* File menu highlight */
    .commit-wb .wb-ribbon span.file-hl {
      background: rgba(255,255,255,0.2);
      border-radius: 3px;
      padding: 0 4px;
      transition: background 0.2s;
    }

    .commit-wb .wb-ribbon span.file-clicked {
      background: rgba(255,255,255,0.4);
    }

    /* Save As modal overlaying the spreadsheet */
    .commit-modal {
      position: absolute;
      top: 50%;
      left: 38%;
      transform: translate(-50%, -50%) scale(0.9);
      width: 260px;
      background: #f7f7f7;
      border-radius: 8px;
      box-shadow: 0 8px 32px rgba(0,0,0,0.4);
      overflow: hidden;
      opacity: 0;
      transition: opacity 0.3s ease, transform 0.3s ease;
      z-index: 10;
    }

    .commit-modal.show {
      opacity: 1;
      transform: translate(-50%, -50%) scale(1);
    }

    /* Dimming overlay behind modal, sized to match spreadsheet */
    .commit-dim {
      position: absolute;
      left: 38%;
      top: 50%;
      width: 400px;
      height: 280px;
