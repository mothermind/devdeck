---
interface Props {
  title?: string;
  agentDocsSlug?: string;
}
const { title = 'DevDeck', agentDocsSlug } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600&family=Fragment+Mono&family=JetBrains+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />
    <title>{title === 'DevDeck' ? 'DevDeck' : `${title} · DevDeck`}</title>
    {agentDocsSlug && (
      <link
        rel="alternate"
        type="application/json"
        href={`/api/docs/${agentDocsSlug}.json`}
        title="Agent-readable spec (JSON)"
      />
    )}
  </head>
  <body>
    <slot />
  </body>
</html>

<!-- Tabs + Segmented Controls -->
<script is:inline>
(function () {
  document.querySelectorAll('.tab-bar').forEach(function (bar) {
    bar.addEventListener('click', function (e) {
      var btn = e.target.closest('.tab-btn');
      if (!btn) return;
      var tabId = btn.dataset.tab;
      var container = bar.closest('.tabs');
      bar.querySelectorAll('.tab-btn').forEach(function (b) {
        b.classList.remove('active');
        b.setAttribute('aria-selected', 'false');
      });
      btn.classList.add('active');
      btn.setAttribute('aria-selected', 'true');
      container.querySelectorAll('.tab-panel').forEach(function (p) { p.classList.remove('active'); });
      var panel = document.getElementById('tab-' + tabId);
      if (panel) panel.classList.add('active');
    });
  });
  document.querySelectorAll('.seg-bar').forEach(function (bar) {
    bar.addEventListener('click', function (e) {
      var btn = e.target.closest('.seg-btn');
      if (!btn) return;
      var segId = btn.dataset.seg;
      var group = btn.dataset.group;
      bar.querySelectorAll('.seg-btn').forEach(function (b) { b.classList.remove('active'); });
      btn.classList.add('active');
      var parent = bar.parentElement;
      parent.querySelectorAll('.seg-panel').forEach(function (p) { p.classList.remove('active'); });
      var panel = document.getElementById('seg-' + group + '-' + segId);
      if (panel) panel.classList.add('active');
    });
  });
})();
</script>

<!-- Copy-to-clipboard for code blocks -->
<script is:inline>
(function () {
  function init() {
    document.querySelectorAll('pre').forEach(function (pre) {
      if (pre.querySelector('.copy-btn')) return;
      var btn = document.createElement('button');
      btn.className = 'copy-btn';
      btn.setAttribute('aria-label', 'Copy');
      btn.innerHTML = '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>';
      btn.addEventListener('click', function () {
        var code = pre.querySelector('code');
        if (!code) return;
        navigator.clipboard.writeText(code.textContent || '').then(function () {
          btn.classList.add('copied');
          btn.innerHTML = '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>';
          setTimeout(function () {
            btn.classList.remove('copied');
            btn.innerHTML = '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>';
          }, 1500);
        });
      });
      pre.appendChild(btn);
    });
  }
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', init);
  } else {
    init();
  }
})();
</script>

<style is:global>
  :root {
    --bg:          #FAF6F0;
    --surface:     #F0EBE3;
    --sidebar-bg:  #EDE8E0;
    --border:      #D5CEC4;
    --border-hi:   #C4BBB0;
    --text:        #1A1A1A;
    --text-muted:  #555555;
    --text-dim:    #888888;
    --accent:      #D4620A;
    --accent-bg:   rgba(212, 98, 10, 0.08);
    --code-bg:     #1A1A1A;
    --code-text:   #E8E8E8;
    --font-heading: 'DM Sans', -apple-system, system-ui, sans-serif;
    --font-sans:    'Fragment Mono', ui-monospace, 'SF Mono', Menlo, monospace;
    --font-mono:    'JetBrains Mono', 'JetBrains Mono Fallback', 'SF Mono', ui-monospace, Menlo, monospace;
    --sidebar-w:   260px;
    --content-max: 900px;
    --header-h:    56px;
  }

  *, *::before, *::after {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }

  html { scroll-behavior: smooth; }

  body {
    background: var(--bg);
    color: var(--text-muted);
    font-family: var(--font-sans);
    font-size: 15px;
    line-height: 1.8;
    -webkit-font-smoothing: antialiased;
  }

  /* ── Headings: DM Sans with tight tracking ── */
  h1, h2, h3, h4, h5 {
    font-family: var(--font-heading);
    font-weight: 700;
    letter-spacing: -0.03em;
    line-height: 1.3;
    color: var(--text);
    scroll-margin-top: calc(var(--header-h) + 1.5rem);
  }

  h1 { font-size: 2rem; }
  h2 { font-size: 1.375rem; margin-top: 2.5rem; margin-bottom: 0.75rem; }
  h3 { font-size: 1.125rem; margin-top: 1.75rem; margin-bottom: 0.5rem; }

  p { margin-bottom: 1rem; }

  a { color: var(--accent); text-decoration: none; }
  a:hover { text-decoration: underline; }

  /* ── Inline code ── */
  code {
    font-family: var(--font-mono);
    font-size: 0.82em;
    font-weight: 500;
    background: rgba(0, 0, 0, 0.05);
    border: 1px solid var(--border);
    border-radius: 6px;
    padding: 0.1em 0.45em;
    color: var(--text);
  }

  /* ── Code blocks ── */
  pre {
    position: relative;
    font-family: var(--font-mono);
    font-size: 0.82rem;
    background: var(--code-bg);
    border: 1px solid rgba(0, 0, 0, 0.12);
    border-radius: 12px;
    padding: 1.1rem 1.4rem;
    padding-right: 3rem; /* room for copy btn */
    overflow-x: auto;
    margin-top: 0.5rem;
    margin-bottom: 2rem;
    line-height: 1.7;
  }

  pre code {
    background: none;
    border: none;
    padding: 0;
    font-size: inherit;
    font-weight: 400;
    color: var(--code-text);
  }

  /* ── Copy button ── */
  .copy-btn {
    position: absolute;
    top: 0.6rem;
    right: 0.6rem;
    width: 26px;
    height: 26px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: transparent;
    border: 1px solid transparent;
    border-radius: 6px;
    color: #666;
    cursor: pointer;
    transition: color 0.15s, border-color 0.15s, background 0.15s;
    padding: 0;
  }

  .copy-btn:hover {
    color: #bbb;
    border-color: #444;
    background: rgba(255, 255, 255, 0.08);
  }

  .copy-btn.copied {
    color: var(--accent);
    border-color: rgba(212, 98, 10, 0.4);
  }

  hr {
    border: none;
    border-top: 1px solid var(--border);
    opacity: 0.6;
    margin: 1.5rem 0;
  }

  table {
    width: 100%;
    border-collapse: collapse;
    margin-bottom: 1.25rem;
    font-size: 0.88rem;
  }

  th {
    text-align: left;
    font-size: 0.68rem;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--text-dim);
    border-bottom: 1px solid var(--border);
    padding: 0.5rem 0.75rem;
  }

  td {
    padding: 0.5rem 0.75rem;
    border-bottom: 1px solid rgba(0, 0, 0, 0.06);
    color: var(--text-muted);
    vertical-align: top;
  }

  td:first-child { color: var(--text); font-family: var(--font-mono); font-size: 0.8rem; }

  strong { font-weight: 600; color: var(--text); }

  ul, ol {
    padding-left: 1.5rem;
    margin-bottom: 1rem;
  }
  li { margin-bottom: 0.35rem; }
  li strong { color: var(--text); }

  /* ── Expanders (details/summary) ── */
  details {
    border: 1px solid var(--border);
    border-radius: 12px;
    margin-bottom: 0.75rem;
    overflow: hidden;
  }

  summary {
    padding: 0.75rem 1.1rem;
    font-size: 0.88rem;
    font-weight: 500;
    color: var(--text-muted);
    cursor: pointer;
    list-style: none;
    display: flex;
    align-items: center;
    gap: 0.5rem;
    background: var(--surface);
    transition: color 0.15s, background 0.15s;
    user-select: none;
  }

  summary::-webkit-details-marker { display: none; }

  summary::before {
    content: '›';
    font-size: 1rem;
    color: var(--text-dim);
    transition: transform 0.2s;
    display: inline-block;
    width: 14px;
  }

  details[open] summary::before { transform: rotate(90deg); }
  details[open] summary { color: var(--text); }

  summary:hover { color: var(--text); background: rgba(0, 0, 0, 0.03); }

  .details-body {
    padding: 1.1rem 1.4rem;
    border-top: 1px solid var(--border);
  }

  /* ── Caption ── */
  .caption {
    font-size: 0.68rem;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--text-dim);
    margin-bottom: 0.75rem;
  }

  /* ── Section tag ── */
  .section-tag {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    color: var(--text-muted);
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 4px;
    padding: 0.15rem 0.5rem;
  }

  /* ── Tabs ── */
  .tabs { margin-top: 1.5rem; }

  .tab-bar {
    display: flex;
    gap: 0;
    border-bottom: 1px solid var(--border);
    margin-bottom: 1.5rem;
    overflow-x: auto;
  }

  .tab-btn {
    background: none;
    border: none;
    border-bottom: 2px solid transparent;
    padding: 0.65rem 1.25rem;
    color: var(--text-muted);
    font-family: var(--font-sans);
    font-size: 0.9rem;
    cursor: pointer;
    white-space: nowrap;
    transition: color 0.15s, border-color 0.15s;
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .tab-btn:hover { color: var(--text); }
  .tab-btn.active { color: var(--accent); border-bottom-color: var(--accent); }
  .tab-btn .section-tag { font-size: 0.7rem; }

  .tab-panel { display: none; }
  .tab-panel.active { display: block; }

  /* ── Segmented Control (subtabs) ── */
  .seg-bar {
    display: inline-flex;
    gap: 2px;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 3px;
    margin-bottom: 1rem;
  }

  .seg-btn {
    background: none;
    border: none;
    border-radius: 6px;
    padding: 0.35rem 0.85rem;
    color: var(--text-muted);
    font-family: var(--font-sans);
    font-size: 0.8rem;
    cursor: pointer;
    transition: color 0.15s, background 0.15s;
    white-space: nowrap;
  }

  .seg-btn:hover { color: var(--text); }
  .seg-btn.active { background: var(--border); color: var(--text); }

  .seg-panel { display: none; }
  .seg-panel.active { display: block; }
</style>
