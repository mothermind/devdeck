---
import Base from './Base.astro';
import Header from '../components/Header.astro';
import Sidebar from '../components/Sidebar.astro';
import TableOfContents from '../components/TableOfContents.astro';

interface Props {
  title?: string;
  showToc?: boolean;
  wide?: boolean;
  agentDocsSlug?: string | string[];
  pipelineManifest?: string;
}
const { title, showToc = true, wide = false, agentDocsSlug, pipelineManifest } = Astro.props;
---

<Base title={title} agentDocsSlug={agentDocsSlug} pipelineManifest={pipelineManifest}>
  <Header />

  <div class="shell">
    <Sidebar />
    <main class={`content${wide ? ' content--wide' : ''}`}>
      <slot />
    </main>
    {showToc && <TableOfContents />}
  </div>
</Base>

<style>
  .shell {
    display: flex;
    min-height: calc(100vh - var(--header-h));
  }

  .content {
    flex: 1;
    margin-left: var(--sidebar-w);
    padding: 3rem 3.5rem;
    max-width: var(--content-max);
    min-height: calc(100vh - var(--header-h));
  }

  .content--wide {
    max-width: none;
  }

  @media (max-width: 900px) {
    .content {
      margin-left: 0;
      padding: 1.75rem 1.5rem;
    }
  }
</style>
