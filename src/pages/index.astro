---
import DocsLayout from '../layouts/DocsLayout.astro';
import PageHeader from '../components/PageHeader.astro';
import dbStatsRaw from '../data/db_stats.json';
import lastRunRaw from '../data/last_run_dates.json';

// ── Types ────────────────────────────────────────────────
interface PgVersion  { version: number; rows: number; active: boolean; created_at?: string; }
interface S3Row      { name: string; objects: number; size_gb: number; }
interface S3DataRow  { name: string; version: string; type: string; files: number; size_gb: number; }
interface DdbRow     { name: string; items: number; size_bytes: number; }

const dbStats = dbStatsRaw as {
  postgresql: Record<string, PgVersion[]>;
  s3: S3Row[];
  s3_data: S3DataRow[];
  dynamodb: DdbRow[];
};
const lastRun = lastRunRaw as Record<string, string>;

// ── Helpers ──────────────────────────────────────────────
const BLOCKS = "▁▂▃▄▅▆▇█";
function spark(values: number[]): string {
  if (!values.length) return "—";
  const [mn, mx] = [Math.min(...values), Math.max(...values)];
  if (mn === mx) return "█".repeat(values.length);
  return values.map(v => BLOCKS[Math.floor((v - mn) / (mx - mn) * 7)]).join("");
}

function fmtDelta(d: number | null): [string, string] {
  if (d === null) return ["—", "var(--text-dim)"];
  if (d === 0)    return ["±0", "var(--text-dim)"];
  const color = d > 0 ? "#2da44e" : "#cf222e";
  const sign = d > 0 ? "+" : "";
  const a = Math.abs(d);
  if (a >= 1_000_000) return [`${sign}${(d/1e6).toFixed(1)}M`, color];
  if (a >= 1_000)     return [`${sign}${Math.round(d/1000)}k`, color];
  return [`${sign}${d.toLocaleString()}`, color];
}

function fmtGb(gb: number): string {
  if (gb >= 100) return `~${Math.round(gb)} GB`;
  if (gb >= 10)  return `~${gb.toFixed(1)} GB`;
  if (gb >= 1)   return `~${gb.toFixed(2)} GB`;
  return `~${Math.round(gb * 1024)} MB`;
}

function fmtBytes(b: number): string {
  const gb = b / 1_073_741_824;
  if (gb >= 1) return fmtGb(gb);
  const mb = b / 1_048_576;
  if (mb >= 1) return `~${Math.round(mb)} MB`;
  return `~${Math.round(b / 1024)} KB`;
}

function fmtAvgMb(sizeGb: number, count: number): string {
  const mb = sizeGb * 1024 / Math.max(count, 1);
  if (mb >= 1000) return `~${(mb/1024).toFixed(1)} GB`;
  if (mb >= 1)    return `~${Math.round(mb)} MB`;
  return `~${Math.round(mb * 1024)} KB`;
}

// ── Build PostgreSQL rows ─────────────────────────────────
interface PgRow {
  name: string; version: string; spark: string;
  rows: number; delta: number | null;
}

function buildPgRows(): PgRow[] {
  return Object.entries(dbStats.postgresql).map(([name, versions]) => {
    const sorted = [...versions].sort((a, b) => a.version - b.version);
    const activeIdx = sorted.findLastIndex(v => v.active);
    const active = sorted[activeIdx >= 0 ? activeIdx : sorted.length - 1];
    const prev = activeIdx > 0 ? sorted[activeIdx - 1] : null;
    return {
      name,
      version: `v${String(active.version).padStart(3, '0')}`,
      spark: spark(sorted.map(v => v.rows)),
      rows: active.rows,
      delta: prev ? active.rows - prev.rows : null,
    };
  }).sort((a, b) => b.rows - a.rows);
}

// ── Sort S3 rows by group total ───────────────────────────
function groupKey(name: string): string {
  const parts = name.replace(/\/$/, "").split("/");
  return parts.length >= 2 ? parts.slice(0, 2).join("/") : parts[0];
}

function sortS3<T extends { name: string; size_gb: number }>(rows: T[]): T[] {
  const totals: Record<string, number> = {};
  rows.forEach(r => { const g = groupKey(r.name); totals[g] = (totals[g] ?? 0) + r.size_gb; });
  return [...rows].sort((a, b) =>
    (totals[groupKey(b.name)] - totals[groupKey(a.name)]) || (b.size_gb - a.size_gb)
  );
}

// ── Pipeline status ───────────────────────────────────────
const TODAY = new Date(); // evaluated at build time

function stageStatus(dateStr: string | undefined): { label: string; color: string; dateStr: string } {
  if (!dateStr) return { label: "—", color: "var(--text-dim)", dateStr: "no record" };
  const d = new Date(dateStr);
  const days = Math.floor((TODAY.getTime() - d.getTime()) / 86_400_000);
  const formatted = d.toLocaleDateString("en-US", { month: "short", day: "numeric" });
  if (days <= 14) return { label: "ok",    color: "#2da44e", dateStr: formatted };
  if (days <= 35) return { label: "stale", color: "#9e6a03", dateStr: formatted };
  return              { label: "old",   color: "#cf222e", dateStr: formatted };
}

const STAGES: [string, string][] = [
  ["OY Scraper",            "OY Scraper"],
  ["BK Scraper",            "BK Scraper"],
  ["Data Loading",          "Step 1: Data Loading"],
  ["Preprocessing",         "Step 2: Preprocessing & Grouping"],
  ["Review Scraper",        "Review Scraper"],
  ["Sentiment Analysis",    "Sentiment Analysis (skincare_analysis)"],
  ["Search Trend",          "Search Trend Scraper"],
  ["OCR Extraction",        "Step 3: OCR Extraction"],
  ["Prep Analysis Data",    "Step 4: Prepare Analysis Data"],
  ["AI Analysis",           "Step 5: AI Analysis"],
  ["Process Results",       "Step 6: Process Analysis Results"],
  ["Feature Engineering",   "Step 7: Feature Engineering"],
  ["Ingredient Embeddings", "Ingredient Embeddings"],
];

const stageCards = STAGES.map(([name, key]) => {
  const s = stageStatus(lastRun[key]);
  return { name, status: s.label, color: s.color, dateStr: s.dateStr };
});

// ── Assemble data ─────────────────────────────────────────
const pgRows   = buildPgRows();
const s3Rows   = sortS3(dbStats.s3);
const s3Data   = sortS3(dbStats.s3_data);
const ddbRows  = [...dbStats.dynamodb].sort((a, b) => b.items - a.items);

const QUICK_LINKS = [
  ["Pipeline",             "/project1/pipeline"],
  ["Scrapers",             "/project1/scrapers"],
  ["Sentiment Analysis",   "/project1/sentiment"],
  ["Ingredient Embeddings","/project1/ingredient-embeddings"],
  ["Search Trend",         "/project1/search-trend"],
  ["Table Manager",        "/project1/table-manager"],
] as const;
---

<DocsLayout title="Dashboard" wide showToc={false}>
  <PageHeader title="Dashboard" tags={["PostgreSQL", "S3", "DynamoDB"]} />

  <div class="section-label">Backend Dev Server</div>
  <pre><code>source venv/bin/activate && python -m app.main</code></pre>

  <!-- ── Pipeline Status ────────────────────────────────── -->
  <div class="section-label">Pipeline Status</div>
  <div class="stage-grid">
    {stageCards.map(s => (
      <div class="stage-card">
        <div class="stage-top">
          <span class="stage-name">{s.name}</span>
          <span class="stage-badge" style={`color:${s.color}`}>{s.status}</span>
        </div>
        <div class="stage-date">{s.dateStr}</div>
      </div>
    ))}
  </div>

  <hr />

  <!-- ── Database Status ────────────────────────────────── -->
  <div class="section-label">Database Status</div>

  <div class="db-layout">
    <!-- Left: PostgreSQL + S3 Data -->
    <div>
      <div class="tbl-label">PostgreSQL</div>
      <table class="db-table">
        <thead><tr>
          <th class="al">table</th>
          <th class="al">ver</th>
          <th class="al">history</th>
          <th class="ar">rows</th>
          <th class="ar">delta</th>
        </tr></thead>
        <tbody>
          {pgRows.map(r => {
            const [dTxt, dColor] = fmtDelta(r.delta);
            return (
              <tr>
                <td class="al mono">{r.name}</td>
                <td class="al" style="color:var(--accent);font-weight:500">{r.version}</td>
                <td class="al spark">{r.spark}</td>
                <td class="ar num">{r.rows.toLocaleString()}</td>
                <td class="ar num" style={`color:${dColor};font-weight:500`}>{dTxt}</td>
              </tr>
            );
          })}
        </tbody>
      </table>

      <div class="tbl-label">S3 · Data</div>
      <table class="db-table">
        <thead><tr>
          <th class="al">path</th>
          <th class="al">version</th>
          <th class="al">type</th>
          <th class="ar">files</th>
          <th class="ar">size</th>
        </tr></thead>
        <tbody>
          {s3Data.map(r => (
            <tr>
              <td class="al mono">{r.name}</td>
              <td class="al" style="color:var(--accent);font-weight:500">{r.version}</td>
              <td class="al spark">{r.type}</td>
              <td class="ar num muted">{r.files.toLocaleString()}</td>
              <td class="ar num">{fmtGb(r.size_gb)}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>

    <!-- Right: S3 Images & DynamoDB -->
    <div>
      <div class="tbl-label">S3 · Images &amp; Models</div>
      <table class="db-table">
        <thead><tr>
          <th class="al">path</th>
          <th class="ar">files</th>
          <th class="ar">avg size</th>
          <th class="ar">total</th>
        </tr></thead>
        <tbody>
          {s3Rows.map(r => (
            <tr>
              <td class="al mono">{r.name}</td>
              <td class="ar num muted">{r.objects.toLocaleString()}</td>
              <td class="ar num muted">{fmtAvgMb(r.size_gb, r.objects)}</td>
              <td class="ar num">{fmtGb(r.size_gb)}</td>
            </tr>
          ))}
        </tbody>
      </table>

      <div class="tbl-label">DynamoDB</div>
      <table class="db-table">
        <thead><tr>
          <th class="al">table</th>
          <th class="ar">items</th>
          <th class="ar">avg size</th>
          <th class="ar">total</th>
        </tr></thead>
        <tbody>
          {ddbRows.map(r => {
            const avgKb = r.size_bytes / Math.max(r.items, 1) / 1024;
            const avgStr = avgKb >= 1 ? `~${avgKb.toFixed(1)} KB` : `~${Math.round(avgKb * 1024)} B`;
            return (
              <tr>
                <td class="al mono">{r.name}</td>
                <td class="ar num">{r.items.toLocaleString()}</td>
                <td class="ar num muted">{avgStr}</td>
                <td class="ar num muted">{fmtBytes(r.size_bytes)}</td>
              </tr>
            );
          })}
        </tbody>
      </table>
    </div>
  </div>

  <hr />

  <!-- ── Quick Access ────────────────────────────────────── -->
  <div class="section-label">Quick Access</div>
  <div class="pills">
    {QUICK_LINKS.map(([label, href]) => (
      <a href={href} class="pill">↳ {label}</a>
    ))}
  </div>
</DocsLayout>

<style>
  /* ── Dashboard container ── */
  :global(.content--wide) {
    max-width: 1100px !important;
  }

  /* ── Section label ── */
  .section-label {
    font-size: 0.68rem;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--text-dim);
    margin-bottom: 0.75rem;
    margin-top: 0.25rem;
  }

  /* ── Stage grid ── */
  .stage-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 0.5rem;
    margin-bottom: 0.5rem;
  }

  .stage-card {
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 0.65rem 0.85rem;
    background: var(--surface);
  }

  .stage-top {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 0.2rem;
  }

  .stage-name {
    font-size: 0.78rem;
    color: var(--text);
    font-weight: 500;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    margin-right: 0.4rem;
  }

  .stage-badge {
    font-size: 0.68rem;
    font-weight: 500;
    flex-shrink: 0;
  }

  .stage-date {
    font-size: 0.67rem;
    color: var(--text-dim);
  }

  /* ── DB layout ── */
  .db-layout {
    display: grid;
    grid-template-columns: 3fr 2fr;
    gap: 2rem;
    align-items: start;
  }

  .tbl-label {
    font-size: 0.68rem;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--text-dim);
    margin-bottom: 0.3rem;
    margin-top: 1rem;
  }

  /* ── DB table ── */
  .db-table {
    width: 100%;
    border-collapse: collapse;
    margin-bottom: 0.25rem;
    font-size: 0.78rem;
  }

  .db-table th {
    font-size: 0.68rem;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--text-dim);
    border-bottom: 1px solid var(--border);
    padding: 0.25rem 0.6rem;
  }

  .db-table td {
    padding: 0.42rem 0.6rem;
    vertical-align: middle;
    border-bottom: none;
  }

  .db-table tr:hover td { background: rgba(0, 0, 0, 0.03); }

  .al { text-align: left; }
  .ar { text-align: right; }

  .mono {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    color: var(--text);
    white-space: nowrap;
  }

  .spark {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    letter-spacing: 0.05em;
    color: var(--text-muted);
  }

  .num {
    font-variant-numeric: tabular-nums;
    color: var(--text);
    white-space: nowrap;
  }

  .muted { color: var(--text-muted) !important; }

  /* ── Pills ── */
  .pills {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    margin-bottom: 1rem;
  }

  .pill {
    display: inline-flex;
    align-items: center;
    padding: 0.2rem 0.75rem;
    border-radius: 20px;
    border: 1px solid var(--border);
    color: var(--text-muted);
    font-size: 0.78rem;
    text-decoration: none;
    background: var(--surface);
    transition: border-color 0.15s, color 0.15s;
  }

  .pill:hover {
    border-color: var(--accent);
    color: var(--accent);
    text-decoration: none;
  }

  @media (max-width: 800px) {
    .stage-grid { grid-template-columns: repeat(2, 1fr); }
    .db-layout  { grid-template-columns: 1fr; }
  }
</style>
