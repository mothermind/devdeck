---
// Standalone page — no layout wrapper
import GitExcelStyles from '../../components/cheatsheet/GitExcelStyles.astro';
import GitExcelSidebar from '../../components/cheatsheet/GitExcelSidebar.astro';
import GitExcelScripts from '../../components/cheatsheet/GitExcelScripts.astro';
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Git, But Make It Excel</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600;700&family=Fredoka:wght@400;500;600;700&family=Fragment+Mono&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
  <GitExcelStyles />
</head>
<body>

  <!-- Mobile toggle -->
  <button class="mobile-toggle" id="mobileToggle" onclick="toggleMobile()">&#9776;</button>
  <div class="sidebar-overlay" id="sidebarOverlay" onclick="toggleMobile()"></div>

  <GitExcelSidebar />

  <!-- ═══════════ MAIN ═══════════ -->
  <div class="main">
    <!-- Panic bar -->
    <div class="panic-bar">
      <div class="panic-input-wrap">
        <span class="panic-icon">&#128269;</span>
        <input class="panic-input" id="panicInput" type="text" placeholder='What happened? Try "undo", "push", "merge"...' autocomplete="off">
        <button class="panic-clear" id="panicClear" onclick="clearPanic()">&times;</button>
        <div class="panic-results" id="panicResults"></div>
      </div>
    </div>

    <div class="content">

      <!-- ────────── GETTING STARTED ────────── -->
      <section id="getting-started">
        <h2>Getting started</h2>
        <p class="section-intro">You need a repo before you can do anything. Think of it like creating or opening a workbook.</p>

        <div class="cmd-card" data-cmd="git init" data-search="git init create new repository blank workbook">
          <div class="cmd-card-header">
            <span class="cmd-name">git init</span>
            <span class="cmd-desc">Create a new repository</span>
          </div>
          <div class="cmd-analogy">
            <span class="cmd-analogy-label">Excel</span>
            Opening Excel and getting that fresh, empty spreadsheet. Nothing in it yet. Pure potential.
          </div>
        </div>

        <!-- Animation: New Workbook (hidden) -->

        <div class="cmd-card" data-cmd="git clone" data-search="git clone download copy repo shared workbook onedrive">
          <div class="cmd-card-header">
            <span class="cmd-name">git clone</span>
            <span class="cmd-desc">Download a copy of someone's repo</span>
          </div>
          <div class="cmd-analogy">
            <span class="cmd-analogy-label">Excel</span>
            Grabbing a copy of your coworker's spreadsheet from the shared drive. Now you've got your own version to mess with.
          </div>
        </div>

        <!-- Animation: git clone -->
        <div class="anim-container">
          <div class="anim-stage anim-clone" id="anim-clone">
            <div class="clone-mon">
              <div class="clone-mon-bezel">
                <div class="clone-screen">

                  <!-- Layer 1: Web view (on top, fades out) -->
                  <div class="clone-web" id="cloneWeb">
                    <div class="clone-web-bar">
                      <div class="clone-web-dots">
                        <div class="clone-web-dot r"></div>
                        <div class="clone-web-dot y"></div>
                        <div class="clone-web-dot g"></div>
                      </div>
                      <div class="clone-web-url">
                        <span class="clone-web-lock">&#9679;</span>
                        onedrive.com/shared/karen/Sales_Q3.xlsx
                      </div>
                    </div>
                    <div class="clone-web-body">
                      <div class="clone-web-hdr">
                        <div class="clone-web-ficon">X</div>
                        <div class="clone-web-fname">Sales_Q3.xlsx</div>
                      </div>
                      <div class="clone-web-meta">Shared by Karen &middot; Last edited 2 hours ago &middot; 24 KB</div>
                      <div class="clone-dl-btn" id="cloneDlBtn">
                        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                          <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/>
                          <polyline points="7 10 12 15 17 10"/>
                          <line x1="12" y1="15" x2="12" y2="3"/>
                        </svg>
                        Download a copy
                      </div>
                    </div>
                  </div>

                  <!-- Layer 2: Desktop view (behind, revealed) -->
                  <div class="clone-desk">
                    <div class="clone-desk-menubar">
                      <div class="clone-desk-menu-l">
                        <span>&#63743;</span><span>Finder</span><span>File</span><span>Edit</span><span>View</span>
                      </div>
                      <div class="clone-desk-menu-r">Thu 3:42 PM</div>
                    </div>
                    <div class="clone-desk-area">
                      <!-- Folder -->
                      <div class="clone-dfolder">
                        <div class="clone-dfolder-icon">
                          <div class="clone-dfolder-tab"></div>
                          <div class="clone-dfolder-body"></div>
                        </div>
                        <div class="clone-dfolder-name">my-project</div>
                      </div>

                      <!-- File (lands here) -->
                      <div class="clone-dfile" id="cloneDFile">
                        <div class="clone-dfile-icon">
                          <span>X</span>
                          <small>.xlsx</small>
                        </div>
                        <div class="clone-dfile-name">Sales_Q3.xlsx</div>
                      </div>

                      <!-- Right-side icons -->
                      <div class="clone-dicons">
                        <div class="clone-dicon">
                          <div class="clone-dicon-img" style="background:#3b82f6">&#128190;</div>
                          <div class="clone-dicon-name">Macintosh HD</div>
                        </div>
                      </div>

                      <!-- Dock -->
                      <div class="clone-ddock">
                        <div class="clone-ddock-item" style="background:#3b82f6">&#128269;</div>
                        <div class="clone-ddock-item" style="background:#e8e8e8">&#128196;</div>
                        <div class="clone-ddock-item" style="background:#217346;color:#fff;font-size:9px;font-weight:700">X</div>
                        <div class="clone-ddock-item" style="background:#555">&#9881;</div>
                        <div class="clone-ddock-item" style="background:#1a1a1a">&#9654;</div>
                      </div>
                    </div>
                  </div>

                </div>
              </div>
              <div class="clone-mon-stand"></div>
              <div class="clone-mon-base"></div>
              <div class="clone-label" id="cloneLabel">Your copy — edit freely</div>
            </div>
          </div>
          <button class="replay-btn" onclick="runCloneAnim()">&#8635;</button>
        </div>

      </section>

      <!-- ────────── SAVING YOUR WORK ────────── -->
      <section id="saving-work">
        <h2>Saving your work</h2>
        <p class="section-intro">Git saves in two steps: first you pick what to include (<code>add</code>), then you save it (<code>commit</code>). It's like highlighting cells before hitting Save.</p>

        <div class="cmd-card" data-cmd="git add filename.txt" data-search="git add filename select changes stage highlight cells specific file">
          <div class="cmd-card-header">
            <span class="cmd-name">git add filename.txt</span>
            <span class="cmd-desc">Select which changes to include in the next save</span>
          </div>
          <div class="cmd-analogy">
            <span class="cmd-analogy-label">Excel</span>
            You edited a bunch of cells, but you're going "I only want to save these ones right now." Click, click, click &mdash; just the ones you pick.
          </div>
        </div>

        <!-- Animation: git add (selective) -->
        <div class="anim-container">
          <div class="anim-stage anim-add" id="anim-add">
            <div class="add-wb">
              <div class="wb-titlebar">
                <div class="wb-dots"><div class="wb-dot r" style="opacity:1;animation:none"></div><div class="wb-dot y" style="opacity:1;animation:none"></div><div class="wb-dot g" style="opacity:1;animation:none"></div></div>
                <div class="wb-title" style="opacity:1;animation:none">Budget_Q3.xlsx — Excel</div>
              </div>
              <div class="wb-ribbon">
                <span style="opacity:1;animation:none">File</span><span style="opacity:1;animation:none">Home</span><span style="opacity:1;animation:none">Insert</span><span style="opacity:1;animation:none">Page Layout</span><span style="opacity:1;animation:none">Formulas</span>
              </div>
              <div class="wb-formula" style="opacity:1;animation:none"><span>A1</span><span style="color:#999;font-style:italic">fx</span></div>
              <div class="wb-grid-area" style="opacity:1;animation:none">
                <div class="wb-rowh">
                  <div style="height:18px"></div><div>1</div><div>2</div><div>3</div><div>4</div><div>5</div><div>6</div><div>7</div><div>8</div><div>9</div><div>10</div>
                </div>
                <div class="wb-grid-inner">
                  <div class="wb-colh"><div>A</div><div>B</div><div>C</div><div>D</div><div>E</div><div>F</div></div>
                  <div class="wb-cells" id="addCells">
                    <div class="wb-row"><div class="wb-cell has-data">Region</div><div class="wb-cell has-data">Q1</div><div class="wb-cell has-data">Q2</div><div class="wb-cell has-data edited" id="ac-d1">Q3</div><div class="wb-cell"></div><div class="wb-cell"></div></div>
                    <div class="wb-row"><div class="wb-cell has-data">North</div><div class="wb-cell has-data">1200</div><div class="wb-cell has-data">1450</div><div class="wb-cell has-data edited" id="ac-d2">1580</div><div class="wb-cell"></div><div class="wb-cell"></div></div>
                    <div class="wb-row"><div class="wb-cell has-data">South</div><div class="wb-cell has-data">980</div><div class="wb-cell has-data edited" id="ac-c3">1320</div><div class="wb-cell has-data edited" id="ac-d3">1100</div><div class="wb-cell"></div><div class="wb-cell"></div></div>
                    <div class="wb-row"><div class="wb-cell has-data">East</div><div class="wb-cell has-data">870</div><div class="wb-cell has-data">920</div><div class="wb-cell has-data edited" id="ac-d4">1050</div><div class="wb-cell"></div><div class="wb-cell"></div></div>
                    <div class="wb-row"><div class="wb-cell has-data">West</div><div class="wb-cell has-data edited" id="ac-b5">760</div><div class="wb-cell has-data">810</div><div class="wb-cell has-data edited" id="ac-d5">940</div><div class="wb-cell"></div><div class="wb-cell"></div></div>
                    <div class="wb-row"><div class="wb-cell"></div><div class="wb-cell"></div><div class="wb-cell"></div><div class="wb-cell"></div><div class="wb-cell"></div><div class="wb-cell"></div></div>
                    <div class="wb-row"><div class="wb-cell"></div><div class="wb-cell"></div><div class="wb-cell"></div><div class="wb-cell"></div><div class="wb-cell"></div><div class="wb-cell"></div></div>
                    <div class="wb-row"><div class="wb-cell"></div><div class="wb-cell"></div><div class="wb-cell"></div><div class="wb-cell"></div><div class="wb-cell"></div><div class="wb-cell"></div></div>
                    <div class="wb-row"><div class="wb-cell"></div><div class="wb-cell"></div><div class="wb-cell"></div><div class="wb-cell"></div><div class="wb-cell"></div><div class="wb-cell"></div></div>
                    <div class="wb-row"><div class="wb-cell"></div><div class="wb-cell"></div><div class="wb-cell"></div><div class="wb-cell"></div><div class="wb-cell"></div><div class="wb-cell"></div></div>
                  </div>
                </div>
              </div>
              <div class="wb-tabs" style="opacity:1;animation:none"><div class="wb-tab">Sheet1</div></div>
              <div class="wb-status"><span style="opacity:1;animation:none">6 cells modified</span></div>
            </div>
            <svg class="add-mouse" id="addMouse" viewBox="0 0 16 20"><path d="M1 1L1 15L5 11L9 18L11 17L7 10L13 10Z" fill="white" stroke="#333" stroke-width="1.2"/></svg>
          </div>
          <div class="anim-legend">
            <div class="leg-item"><div class="leg-dot untouched"></div> Unchanged</div>
            <div class="leg-item"><div class="leg-dot edited"></div> Edited (unstaged)</div>
            <div class="leg-item"><div class="leg-dot staged"></div> Staged (git add)</div>
          </div>
          <button class="replay-btn" onclick="runAddAnim()">&#8635;</button>
        </div>

        <div class="cmd-card" data-cmd="git add ." data-search="git add . all changes select all save everything">
          <div class="cmd-card-header">
            <span class="cmd-name">git add .</span>
            <span class="cmd-desc">Select all changes</span>
          </div>
          <div class="cmd-analogy">
            <span class="cmd-analogy-label">Excel</span>
            Ctrl+A, done. Just grab everything you touched and throw it all in the save. No picking and choosing.
          </div>
        </div>

        <!-- Animation: git add . (select all) -->
        <div class="anim-container">
          <div class="anim-stage anim-add" id="anim-add-all">
            <div class="add-wb">
              <div class="wb-titlebar">
                <div class="wb-dots"><div class="wb-dot r" style="opacity:1;animation:none"></div><div class="wb-dot y" style="opacity:1;animation:none"></div><div class="wb-dot g" style="opacity:1;animation:none"></div></div>
                <div class="wb-title" style="opacity:1;animation:none">Budget_Q3.xlsx — Excel</div>
              </div>
              <div class="wb-ribbon">
                <span style="opacity:1;animation:none">File</span><span style="opacity:1;animation:none">Home</span><span style="opacity:1;animation:none">Insert</span><span style="opacity:1;animation:none">Page Layout</span><span style="opacity:1;animation:none">Formulas</span>
              </div>
              <div class="wb-formula" style="opacity:1;animation:none"><span>A1</span><span style="color:#999;font-style:italic">fx</span></div>
              <div class="wb-grid-area" style="opacity:1;animation:none">
                <div class="wb-rowh">
                  <div style="height:18px"></div><div>1</div><div>2</div><div>3</div><div>4</div><div>5</div><div>6</div><div>7</div><div>8</div><div>9</div><div>10</div>
                </div>
                <div class="wb-grid-inner">
                  <div class="wb-colh"><div>A</div><div>B</div><div>C</div><div>D</div><div>E</div><div>F</div></div>
                  <div class="wb-cells" id="addAllCells">
                    <div class="wb-row"><div class="wb-cell has-data">Region</div><div class="wb-cell has-data">Q1</div><div class="wb-cell has-data">Q2</div><div class="wb-cell has-data edited" id="aa-d1">Q3</div><div class="wb-cell"></div><div class="wb-cell"></div></div>
                    <div class="wb-row"><div class="wb-cell has-data">North</div><div class="wb-cell has-data">1200</div><div class="wb-cell has-data">1450</div><div class="wb-cell has-data edited" id="aa-d2">1580</div><div class="wb-cell"></div><div class="wb-cell"></div></div>
                    <div class="wb-row"><div class="wb-cell has-data">South</div><div class="wb-cell has-data">980</div><div class="wb-cell has-data edited" id="aa-c3">1320</div><div class="wb-cell has-data edited" id="aa-d3">1100</div><div class="wb-cell"></div><div class="wb-cell"></div></div>
                    <div class="wb-row"><div class="wb-cell has-data">East</div><div class="wb-cell has-data">870</div><div class="wb-cell has-data">920</div><div class="wb-cell has-data edited" id="aa-d4">1050</div><div class="wb-cell"></div><div class="wb-cell"></div></div>
                    <div class="wb-row"><div class="wb-cell has-data">West</div><div class="wb-cell has-data edited" id="aa-b5">760</div><div class="wb-cell has-data">810</div><div class="wb-cell has-data edited" id="aa-d5">940</div><div class="wb-cell"></div><div class="wb-cell"></div></div>
                    <div class="wb-row"><div class="wb-cell"></div><div class="wb-cell"></div><div class="wb-cell"></div><div class="wb-cell"></div><div class="wb-cell"></div><div class="wb-cell"></div></div>
                    <div class="wb-row"><div class="wb-cell"></div><div class="wb-cell"></div><div class="wb-cell"></div><div class="wb-cell"></div><div class="wb-cell"></div><div class="wb-cell"></div></div>
                    <div class="wb-row"><div class="wb-cell"></div><div class="wb-cell"></div><div class="wb-cell"></div><div class="wb-cell"></div><div class="wb-cell"></div><div class="wb-cell"></div></div>
                    <div class="wb-row"><div class="wb-cell"></div><div class="wb-cell"></div><div class="wb-cell"></div><div class="wb-cell"></div><div class="wb-cell"></div><div class="wb-cell"></div></div>
                    <div class="wb-row"><div class="wb-cell"></div><div class="wb-cell"></div><div class="wb-cell"></div><div class="wb-cell"></div><div class="wb-cell"></div><div class="wb-cell"></div></div>
                  </div>
                </div>
              </div>
              <div class="wb-tabs" style="opacity:1;animation:none"><div class="wb-tab">Sheet1</div></div>
              <div class="wb-status"><span style="opacity:1;animation:none" id="aa-status">6 cells modified</span></div>
            </div>
          </div>
          <div class="anim-legend">
            <div class="leg-item"><div class="leg-dot untouched"></div> Unchanged</div>
            <div class="leg-item"><div class="leg-dot edited"></div> Edited (unstaged)</div>
            <div class="leg-item"><div class="leg-dot staged"></div> Staged (git add .)</div>
          </div>
          <button class="replay-btn" onclick="runAddAllAnim()">&#8635;</button>
        </div>

        <div class="cmd-card" data-cmd="git commit" data-search="git commit save snapshot note version save as">
          <div class="cmd-card-header">
            <span class="cmd-name">git commit</span>
            <span class="cmd-desc">Save a snapshot with a note</span>
          </div>
          <div class="cmd-analogy">
            <span class="cmd-analogy-label">Excel</span>
            Hit Save As and scribble "Q3 numbers done" in the comment box. Now it's in your version history forever.
          </div>
        </div>

        <div class="cmd-card" data-cmd='git commit -m "message"' data-search="git commit -m message one-line description save as comment box">
          <div class="cmd-card-header">
            <span class="cmd-name">git commit -m "message"</span>
            <span class="cmd-desc">Save with a one-line description</span>
          </div>
          <div class="cmd-analogy">
            <span class="cmd-analogy-label">Excel</span>
            That little comment box in Save As? Yeah, that. One line, keep it short, move on.
          </div>
        </div>

        <!-- Animation: git commit -m -->
        <div class="anim-container">
          <div class="anim-stage anim-commit" id="anim-commit">
            <div class="commit-wb">
              <div class="wb-titlebar">
                <div class="wb-dots"><div class="wb-dot r" style="opacity:1;animation:none"></div><div class="wb-dot y" style="opacity:1;animation:none"></div><div class="wb-dot g" style="opacity:1;animation:none"></div></div>
                <div class="wb-title" style="opacity:1;animation:none">Budget_Q3.xlsx — Excel</div>
              </div>
              <div class="wb-ribbon">
                <span style="opacity:1;animation:none" class="file-hl" id="commitFileMenu">File</span><span style="opacity:1;animation:none">Home</span><span style="opacity:1;animation:none">Insert</span><span style="opacity:1;animation:none">Page Layout</span><span style="opacity:1;animation:none">Formulas</span>
              </div>
              <div class="wb-formula" style="opacity:1;animation:none"><span>A1</span><span style="color:#999;font-style:italic">fx</span></div>
              <div class="wb-grid-area" style="opacity:1;animation:none">
                <div class="wb-rowh">
                  <div style="height:18px"></div><div>1</div><div>2</div><div>3</div><div>4</div><div>5</div><div>6</div><div>7</div><div>8</div><div>9</div><div>10</div>
                </div>
                <div class="wb-grid-inner">
                  <div class="wb-colh"><div>A</div><div>B</div><div>C</div><div>D</div><div>E</div><div>F</div></div>
                  <div class="wb-cells">
                    <div class="wb-row"><div class="wb-cell has-data">Region</div><div class="wb-cell has-data">Q1</div><div class="wb-cell has-data">Q2</div><div class="wb-cell has-data staged">Q3</div><div class="wb-cell"></div><div class="wb-cell"></div></div>
                    <div class="wb-row"><div class="wb-cell has-data">North</div><div class="wb-cell has-data">1200</div><div class="wb-cell has-data">1450</div><div class="wb-cell has-data staged">1580</div><div class="wb-cell"></div><div class="wb-cell"></div></div>
                    <div class="wb-row"><div class="wb-cell has-data">South</div><div class="wb-cell has-data">980</div><div class="wb-cell has-data staged">1320</div><div class="wb-cell has-data staged">1100</div><div class="wb-cell"></div><div class="wb-cell"></div></div>
                    <div class="wb-row"><div class="wb-cell has-data">East</div><div class="wb-cell has-data">870</div><div class="wb-cell has-data">920</div><div class="wb-cell has-data staged">1050</div><div class="wb-cell"></div><div class="wb-cell"></div></div>
                    <div class="wb-row"><div class="wb-cell has-data">West</div><div class="wb-cell has-data staged">760</div><div class="wb-cell has-data">810</div><div class="wb-cell has-data staged">940</div><div class="wb-cell"></div><div class="wb-cell"></div></div>
                    <div class="wb-row"><div class="wb-cell"></div><div class="wb-cell"></div><div class="wb-cell"></div><div class="wb-cell"></div><div class="wb-cell"></div><div class="wb-cell"></div></div>
                    <div class="wb-row"><div class="wb-cell"></div><div class="wb-cell"></div><div class="wb-cell"></div><div class="wb-cell"></div><div class="wb-cell"></div><div class="wb-cell"></div></div>
                    <div class="wb-row"><div class="wb-cell"></div><div class="wb-cell"></div><div class="wb-cell"></div><div class="wb-cell"></div><div class="wb-cell"></div><div class="wb-cell"></div></div>
                    <div class="wb-row"><div class="wb-cell"></div><div class="wb-cell"></div><div class="wb-cell"></div><div class="wb-cell"></div><div class="wb-cell"></div><div class="wb-cell"></div></div>
                    <div class="wb-row"><div class="wb-cell"></div><div class="wb-cell"></div><div class="wb-cell"></div><div class="wb-cell"></div><div class="wb-cell"></div><div class="wb-cell"></div></div>
                  </div>
                </div>
              </div>
              <div class="wb-tabs" style="opacity:1;animation:none"><div class="wb-tab">Sheet1</div></div>
              <div class="wb-status" id="commitStatus"><span style="opacity:1;animation:none">6 cells staged &#10003;</span></div>
            </div>

            <!-- Dim overlay (outside wb so not clipped) -->
            <div class="commit-dim" id="commitDim"></div>

            <!-- Save As modal centered on spreadsheet -->
            <div class="commit-modal" id="commitModal">
              <div class="commit-modal-bar">
                <div class="commit-modal-dots"><div class="commit-modal-dot r"></div><div class="commit-modal-dot y"></div><div class="commit-modal-dot g"></div></div>
                <div class="commit-modal-title">Save As</div>
              </div>
              <div class="commit-modal-body">
                <div class="commit-modal-label">Save As:</div>
                <div class="commit-modal-input" id="commitInput">
                  <span class="commit-typing-text" id="commitTyping"></span><span class="commit-typing-cursor" id="commitCursor"></span>
                </div>
                <div class="commit-modal-where">Where: <span>~/my-project/</span></div>
                <div class="commit-modal-actions">
                  <div class="commit-btn-cancel">Cancel</div>
                  <div class="commit-btn-save" id="commitSaveBtn">Save</div>
                </div>
              </div>
            </div>

            <!-- Right: version files -->
            <div class="commit-files">
              <div class="commit-file" id="commitOrigFile">
                <div class="commit-file-icon"><span>X</span><small>.xlsx</small></div>
                <div class="commit-file-info">
                  <div class="commit-file-name">Budget_Q3.xlsx</div>
                  <div class="commit-file-meta">Original &middot; v1</div>
                </div>
              </div>
              <div class="commit-file new-file" id="commitNewFile">
