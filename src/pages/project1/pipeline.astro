---
import DocsLayout from '../../layouts/DocsLayout.astro';
import PageHeader from '../../components/PageHeader.astro';
import { stages, GROUP_LABEL } from '../../data/pipeline';

const MERMAID = `flowchart TD
    OY([OY Scraper]) & BK([BK Scraper]) --> DDB1[(DynamoDB + S3)]
    DDB1 --> S1(Step 1: Data Loading) --> S2(Step 2: Preprocessing & Grouping) --> PG1[(product_raw)]
    PG1 --> REV([Review Scraper]) --> S3R[(S3: reviews)]
    S3R --> SENT(Sentiment Analysis) --> PG2[(product_review)]
    PG2 --> TREND([Search Trend Scraper]) --> PG3[(product_search_trend)]

    DDB1 --> S3(Step 3: OCR Extraction) --> DDB2[(ItemKeywords)]
    PG1 --> S4
    DDB2 --> S4(Step 4: Prepare Analysis Data) --> S5(Step 5: AI Analysis) --> S6(Step 6: Process Results) --> PG4[(product_analysis)]
    PG4 --> S7(Step 7: Feature Engineering) --> PG5[(product_service)]
    PG4 --> INGR([Ingredient Embeddings]) --> API{API}

    classDef scraper fill:#FFF3EB,stroke:#D4620A,stroke-width:1.5px,color:#D4620A
    classDef process fill:#EDF7EF,stroke:#2d8a4e,stroke-width:1.5px,color:#2d8a4e
    classDef storage fill:#FDF6E3,stroke:#b8860b,stroke-width:1.5px,color:#b8860b
    classDef api    fill:#F3F0FA,stroke:#7c5cbf,stroke-width:1.5px,color:#7c5cbf

    class OY,BK,REV,TREND,INGR scraper
    class S1,S2,S3,S4,S5,S6,S7,SENT process
    class DDB1,DDB2,S3R,PG1,PG2,PG3,PG4,PG5 storage
    class API api`;
---

<DocsLayout title="Data Pipeline" pipelineManifest="/api/pipeline.json">
  <PageHeader
    title="Data Pipeline Architecture"
    tags={["13 stages", "DynamoDB + S3", "PostgreSQL"]}
    pipelineManifest="/api/pipeline.json"
  />

  <!-- ── Diagram ── -->
  <section class="stage-section">
    <h2>Pipeline Diagram</h2>
    <div class="diagram-wrap">
      <div class="mermaid">{MERMAID}</div>
    </div>
  </section>

  <!-- ── Stage sections ── -->
  {stages.map((s, i) => (
    <section class="stage-section">
      <div class="stage-eyebrow">
        <span class="stage-badge">Stage {String(i + 1).padStart(2, '0')}</span>
        <span class="eyebrow-sep">·</span>
        <span class="eyebrow-group">{GROUP_LABEL[s.id]}</span>
      </div>

      <h2>{s.name}</h2>

      {s.github
        ? <a href={s.github} target="_blank" rel="noopener" class="project-link">{s.project} ↗</a>
        : <span class="project-label">{s.project}</span>
      }

      <p class="stage-desc">{s.description}</p>

      <div class="stage-body">
        <!-- Left: What it does -->
        <div class="spec-card feat-card">
          <div class="spec-title">What it does</div>
          <ul class="feature-list">
            {s.features.map(f => <li>{f}</li>)}
          </ul>
        </div>

        <!-- Right: Tech Stack + IO stacked -->
        <div class="body-right">
          <div class="spec-card">
            <div class="spec-title">Tech Stack</div>
            <div class="tech-badges">
              {s.tech.map(t => <span class="tech-badge">{t}</span>)}
            </div>
          </div>

          <div class="spec-card io-card">
            <div class="io-half">
              <div class="spec-title">Input</div>
              <p class="io-value">{s.source}</p>
            </div>
            <div class="io-divider">↓</div>
            <div class="io-half">
              <div class="spec-title">Output</div>
              <div class="dest-list">
                {s.destination.map(d => (
                  <div class="dest-row">
                    <span class="dest-tag">{d.label}</span>
                    <code class="dest-val">{d.value}</code>
                    {d.note && <span class="dest-note">{d.note}</span>}
                  </div>
                ))}
              </div>
            </div>
          </div>
        </div>
      </div>

      {s.notes && (
        <div class="notes-block">
          <p class="notes-text">{s.notes}</p>
        </div>
      )}

      {s.schema && (
        <details class="schema-details">
          <summary>Output Schema</summary>
          <div class="details-body">
            <pre><code>{JSON.stringify(s.schema, null, 2)}</code></pre>
          </div>
        </details>
      )}

      {s.guide && (
        <a href={s.guide} class="guide-link">{s.guideLabel} →</a>
      )}
    </section>
  ))}
</DocsLayout>

<!-- Mermaid CDN + init -->
<script is:inline>
(function () {
  var s = document.createElement('script');
  s.src = 'https://cdn.jsdelivr.net/npm/mermaid@11/dist/mermaid.min.js';
  s.onload = function () {
    mermaid.initialize({
      startOnLoad: true,
      theme: 'base',
      themeVariables: {
        fontFamily: "'JetBrains Mono', ui-monospace, Menlo, monospace",
        fontSize: '12px',
        primaryColor: '#F0EBE3',
        primaryBorderColor: '#D5CEC4',
        primaryTextColor: '#1A1A1A',
        lineColor: '#C4BBB0',
        edgeLabelBackground: 'transparent',
        clusterBkg: '#FAF6F0',
        clusterBorder: '#D5CEC4',
        titleColor: '#888888',
        nodeTextColor: '#1A1A1A',
        secondaryColor: '#F0EBE3',
        tertiaryColor: '#F0EBE3',
      },
      flowchart: { nodeSpacing: 30, rankSpacing: 50, curve: 'basis', padding: 20 },
    });
  };
  document.head.appendChild(s);
})();
</script>

<style>
  /* ── Diagram ── */
  :global(.mermaid svg) { width: 100% !important; height: auto !important; }

  /* ── Section spacing ── */
  .stage-section {
    padding-bottom: 3.5rem;
    margin-bottom: 1rem;
    border-bottom: 1px solid var(--border);
  }
  .stage-section:last-child { border-bottom: none; }

  /* ── Diagram ── */
  .diagram-wrap {
    margin-top: 1.5rem;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 1.5rem;
    overflow-x: auto;
  }

  /* ── Eyebrow ── */
  .stage-eyebrow {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    margin-bottom: 0.75rem;
  }

  .stage-badge {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    font-weight: 500;
    color: var(--accent);
    background: var(--accent-bg);
    border: 1px solid rgba(83, 155, 245, 0.25);
    border-radius: 6px;
    padding: 0.18rem 0.6rem;
    letter-spacing: 0.04em;
  }

  .eyebrow-sep { color: var(--border-hi); font-size: 0.78rem; }

  .eyebrow-group {
    font-family: var(--font-sans);
    font-size: 0.68rem;
    font-weight: 500;
    color: var(--text-dim);
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  /* ── Project link / label ── */
  .project-link, .project-label {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: 0.8rem;
    margin-bottom: 1rem;
    color: var(--accent);
    text-decoration: none;
  }
  .project-label { color: var(--text-dim); }
  .project-link:hover { text-decoration: underline; }

  /* ── Description ── */
  .stage-desc {
    font-size: 0.975rem;
    color: var(--text-muted);
    line-height: 1.75;
    margin-bottom: 1.75rem;
    max-width: 700px;
  }

  /* ── Stage body: 2-col unified block ── */
  .stage-body {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.25rem;
    align-items: start;
    margin-bottom: 1.5rem;
  }

  .body-right {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .spec-card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 1.25rem 1.5rem;
  }

  /* feat-card stretches to match right column height */
  .feat-card {
    height: 100%;
    box-sizing: border-box;
  }

  .spec-title {
    font-family: var(--font-sans);
    font-size: 0.68rem;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--text-dim);
    margin-bottom: 1rem;
    margin-top: 0;
  }

  .feature-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }

  .feature-list li {
    display: flex;
    align-items: flex-start;
    gap: 0.6rem;
    font-size: 0.85rem;
    color: var(--text-muted);
    line-height: 1.6;
    margin: 0;
  }

  .feature-list li::before {
    content: '✓';
    color: #3fb950;
    font-size: 0.75rem;
    flex-shrink: 0;
    margin-top: 0.15rem;
  }

  .tech-badges {
    display: flex;
    flex-wrap: wrap;
    gap: 0.45rem;
  }

  .tech-badge {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    color: var(--text-muted);
    background: var(--bg);
    border: 1px solid var(--border);
    border-radius: 999px;
    padding: 0.18rem 0.7rem;
  }

  /* ── IO card ── */
  .io-card {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .io-half { padding: 0.2rem 0; }
  .io-half + .io-half { padding-top: 0.85rem; }

  .io-divider {
    text-align: center;
    font-size: 0.75rem;
    color: var(--border-hi);
    padding: 0.4rem 0;
    border-top: 1px dashed var(--border);
    margin-top: 0.85rem;
  }

  .io-value {
    font-size: 0.85rem;
    color: var(--text-muted);
    line-height: 1.55;
    margin: 0;
  }

  .dest-list { display: flex; flex-direction: column; gap: 0.4rem; }
  .dest-row  { display: flex; align-items: baseline; gap: 0.5rem; flex-wrap: wrap; }

  .dest-tag {
    font-size: 0.75rem;
    color: var(--text-dim);
    min-width: 4.5rem;
  }

  .dest-val {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    color: var(--text);
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 4px;
    padding: 0.1em 0.4em;
  }

  .dest-note {
    font-size: 0.78rem;
    color: var(--text-dim);
  }

  /* ── Notes ── */
  .notes-block {
    border-left: 3px solid rgba(83, 155, 245, 0.3);
    padding: 0.65rem 1.1rem;
    margin-bottom: 1.25rem;
    background: rgba(83, 155, 245, 0.04);
    border-radius: 0 8px 8px 0;
  }

  .notes-text {
    font-size: 0.85rem;
    color: var(--text-dim);
    line-height: 1.7;
    margin: 0;
    font-style: italic;
  }

  /* ── Schema details ── */
  .schema-details {
    margin-bottom: 1.25rem;
  }

  .schema-details summary {
    font-size: 0.85rem;
  }

  .schema-details .details-body { padding: 1rem 1.25rem; }
  .schema-details pre { margin: 0; font-size: 0.8rem; }

  /* ── Guide link ── */
  .guide-link {
    display: inline-block;
    margin-top: 0.5rem;
    font-size: 0.85rem;
    color: var(--accent);
    text-decoration: none;
    border: 1px solid var(--border);
    border-radius: 20px;
    padding: 0.3rem 1.1rem;
    background: var(--bg);
    transition: border-color 0.15s;
  }
  .guide-link:hover { border-color: var(--accent); text-decoration: none; }

  /* ── Responsive ── */
  @media (max-width: 680px) {
    .stage-body { grid-template-columns: 1fr; }
    .feat-card { height: auto; }
  }
</style>
